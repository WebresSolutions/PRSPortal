{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    // uses the internal Docker network to connect to the Postgres container
    "PrsConnection": ""
  },
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "ClientId": "",
    "TenantId": "",
    "Audience": ""
  },
  "ApiSettings": {
    "EnableSwagger": true,
    "EnableDetailedErrors": true,
    "EnableApiExplorer": true,
    "StandaloneMode": true
  },
  "XeroSettings": {
    "AccessToken": "",
    "TenantId": ""
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://+:9900"
      },
      "Https": {
        "Url": "https://+:9901"
      }
    }
  }
}
