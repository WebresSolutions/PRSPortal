@page "/contacts/edit/{ContactId:int}"
@inherits BaseDataComponent
@using Portal.Client.Components.JobComponents
@using Portal.Shared
@using Portal.Shared.DTO
@using Portal.Shared.DTO.Address
@using Portal.Shared.DTO.Contact

<PageTitle>Edit Contact - PRS Portal</PageTitle>

<div class="container">
    <PageHeader>
        <Content>
            <div style="min-width: 150px">
                <h2>Edit Contact</h2>
            </div>
        </Content>
    </PageHeader>
    <Card>
        @if (base.IsLoading)
        {
            <MudSkeleton Height="600px;" />
        }
        else
        {
            @if (_model is not null)
            {
                <EditForm Model="@_model" class="create-contact-form">
                    <DataAnnotationsValidator />
                    <ValidationSummary />
                    <div class="form-grid">
                        <div class="">
                            <h3 class="form-section-title border-bottom pb-2">Contact Details</h3>
                            <div class="form-sections border-rad border-grey">
                                <div>
                                    <label for="contact-type">Contact Type</label>
                                    <MudSelect InputClass="mb-2" name="contact-type" T="int" @bind-Value="_model.TypeId" Variant="Variant.Outlined" Class="mb-3" For="@(() => _model.TypeId)" Required="true" SelectedValuesChanged="@(() => _model.ParentContactId = null)">
                                        @foreach (var t in _contactTypes)
                                        {
                                            <MudSelectItem T="int" Value="@t.Id" Class="text-center"><ContactTypeBadge ContactType="@((ContactTypeEnum)t.Id)" /></MudSelectItem>
                                        }
                                    </MudSelect>
                                </div>

                                @if ((ContactTypeEnum)_model.TypeId is ContactTypeEnum.Individual)
                                {
                                    <div>
                                        <label for="parent-contact">Parent Contact</label>
                                        <ContactAutocomplete Name="parent-contact" Value="_parentContact" ValueChanged="OnParentContactChanged"
                                                             Clearable="true" SearchPageSize="500" />
                                    </div>
                                }

                                <div>
                                    <label for="first-name">First Name</label>
                                    <MudTextField name="first-name" @bind-Value="_model.FirstName" Variant="Variant.Outlined" Class="mb-3" For="@(() => _model.FirstName)" Required="true" />
                                </div>

                                <div>
                                    <label for="last-name">Last Name</label>
                                    <MudTextField name="last-name" @bind-Value="_model.LastName" Variant="Variant.Outlined" Class="mb-3" For="@(() => _model.LastName)" Required="true" />
                                </div>

                                <div>
                                    <label for="email">Email</label>
                                    <MudTextField name="email" @bind-Value="_model.Email" Variant="Variant.Outlined" Class="mb-3" For="@(() => _model.Email)" Required="true" InputType="InputType.Email" />
                                </div>

                                <div>
                                    <label for="phone">Phone</label>
                                    <MudTextField name="phone" @bind-Value="_model.Phone" Variant="Variant.Outlined" Class="mb-3" For="@(() => _model.Phone)" />
                                </div>

                                <div>
                                    <label for="fax">Fax</label>
                                    <MudTextField name="fax" @bind-Value="_model.Fax" Variant="Variant.Outlined" Class="mb-3" For="@(() => _model.Fax)" />
                                </div>
                            </div>
                        </div>

                        @if (_model.Address is not null)
                        {
                            <EditAddress Address="_model.Address" />
                        }
                    </div>
                    <div class="form-actions">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Success"
                                   StartIcon="@Icons.Material.Filled.Save"
                                   OnClick="SubmitAsync">
                            Save
                        </MudButton>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Error"
                                   StartIcon="@Icons.Material.Filled.Close"
                                   Href="/contacts">
                            Close
                        </MudButton>
                    </div>
                </EditForm>
            }
            @if (_model is null)
            {
                <small>Contact not found or could not be loaded.</small>
            }
        }
    </Card>
</div>

<style>
    .create-contact-form {
        margin: 0;
    }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: calc(2 * var(--padding));
        align-items: start;
    }

    .form-sections {
        display: flex;
        flex-direction: column;
        gap: var(--padding);
        padding: calc(2 * var(--padding));
        background-color: var(--color-light-grey);
    }

    .form-section-title {
        font-size: 1rem;
        margin: 1rem 0 0.5rem;
    }

    .form-actions {
        display: flex;
        gap: 0.5rem;
        margin-top: 1.5rem;
        justify-content: center;
    }

    @@media (max-width: 900px) {
        .form-grid {
            grid-template-columns: 1fr;
        }
    }

    .border-rad {
        border-radius: 8px;
    }
</style>
