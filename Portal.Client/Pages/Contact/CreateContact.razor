@page "/contacts/create"
@inherits BaseDataComponent
@using Portal.Client.Components.JobComponents
@using Portal.Shared
@using Portal.Shared.DTO.Contact
@using Portal.Shared.DTO.Address

<PageTitle>Create Contact - PRS Portal</PageTitle>

<div class="container">
    <PageHeader>
        <Content>
            <div style="min-width: 150px">
                <h2>Create New Contact</h2>
            </div>
            <div>
                <ButtonIcon Href="/contacts" Icon="bi bi-sign-turn-left" />
            </div>
        </Content>
    </PageHeader>

    <Card>
        <ChildContent>
            @if (base.IsLoading)
            {
                <MudSkeleton Height="600px;" />
            }
            else
            {
                <EditForm Model="@_model" class="create-contact-form" OnValidSubmit="SubmitAsync">
                    <DataAnnotationsValidator />
                    <div class="form-grid">
                        <div>
                            <h3 class="form-section-title border-bottom pb-2">Contact Details</h3>
                            <div class="form-sections border-rad border-grey">
                                <div>
                                    <label for="contact-type">Contact Type</label>
                                    <MudSelect name="contact-type" T="int" @bind-Value="_model.TypeId" Variant="Variant.Outlined" Class="mb-3" For="@(() => _model.TypeId)" Required="true" InputClass="mb-2">
                                        @foreach (var t in _contactTypes)
                                        {
                                            <MudSelectItem T="int" Value="@t.Id" Class="text-center"><ContactTypeBadge ContactType="@((ContactTypeEnum)t.Id)" /></MudSelectItem>
                                        }
                                    </MudSelect>
                                </div>

                                @if ((ContactTypeEnum)_model.TypeId is ContactTypeEnum.Individual)
                                {
                                    <div>
                                        <label for="parent-contact">Parent Contact</label>
                                        <MudAutocomplete name="parent-contact" T="ListContactDto" Value="_parentContact" ValueChanged="OnParentContactChanged" Clearable="true" Variant="Variant.Outlined" DebounceInterval="100"
                                                         SearchFunc="@SearchContacts" ToStringFunc="@(e => e.ToString())" MaxItems="50">
                                            <MoreItemsTemplate>
                                                <div class="d-flex justify-content-center">
                                                    <small>Only the first 50 items are shown</small>
                                                </div>
                                            </MoreItemsTemplate>
                                        </MudAutocomplete>
                                    </div>
                                }

                                <div>
                                    <label for="first-name">First Name</label>
                                    <MudTextField name="first-name" @bind-Value="_model.FirstName" Variant="Variant.Outlined" Class="mb-3" For="@(() => _model.FirstName)" Required="true" />
                                </div>

                                <div>
                                    <label for="last-name">Last Name</label>
                                    <MudTextField name="last-name" @bind-Value="_model.LastName" Variant="Variant.Outlined" Class="mb-3" For="@(() => _model.LastName)" Required="true" />
                                </div>

                                <div>
                                    <label for="email">Email</label>
                                    <MudTextField name="email" @bind-Value="_model.Email" Variant="Variant.Outlined" Class="mb-3" For="@(() => _model.Email)" Required="true" InputType="InputType.Email" />
                                </div>

                                <div>
                                    <label for="phone">Phone</label>
                                    <MudTextField name="phone" @bind-Value="_model.Phone" Variant="Variant.Outlined" Class="mb-3" For="@(() => _model.Phone)" />
                                </div>

                                <div>
                                    <label for="fax">Fax</label>
                                    <MudTextField name="fax" @bind-Value="_model.Fax" Variant="Variant.Outlined" Class="mb-3" For="@(() => _model.Fax)" />
                                </div>
                            </div>
                            <ValidationSummary />
                        </div>

                        @if (_model.Address is not null && _model.Address.LatLng is not null)
                        {
                            <EditAddress Address="_model.Address" />
                        }
                    </div>
                    <div class="form-actions">
                        <ButtonIcon Icon="bi bi-save-fill" CssClass="text-green" Text="Save" ButtonType="submit" />
                        <ButtonIcon Icon="bi bi-x-circle" CssClass="text-red" Href="/contacts" Text="Close" />
                    </div>
                </EditForm>
            }
        </ChildContent>
    </Card>
</div>

<style>
    .create-contact-form {
        margin: 0;
    }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: calc(2 * var(--padding));
        align-items: start;
    }

    .form-sections {
        display: flex;
        flex-direction: column;
        gap: var(--padding);
        padding: calc(2 * var(--padding));
        background-color: var(--color-light-grey);
    }

    .form-section-title {
        font-size: 1rem;
        margin: 1rem 0 0.5rem;
    }

    .form-actions {
        display: flex;
        gap: 0.5rem;
        margin-top: 1.5rem;
        justify-content: center;
    }

    @@media (max-width: 900px) {
        .form-grid {
            grid-template-columns: 1fr;
        }
    }

    .border-rad {
        border-radius: 8px;
    }
</style>
