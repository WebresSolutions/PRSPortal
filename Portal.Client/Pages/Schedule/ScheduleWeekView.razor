@page "/week"
@page "/week/{date?}/{jobType:int?}"
@using Portal.Client.Components.ScheduleComponents
@using Portal.Shared
@using Portal.Shared.DTO.Schedule
@inherits BaseDataComponent

<PageTitle>Schedule Week - PRS Portal</PageTitle>
<div class="container">
    <PageHeader>
        <Content>
            <div class="header-left">
                <div class="header-content">
                    <h1>Schedule week – @_jobTypeEnum.GetDisplayName()</h1>
                    <div class="header-info">
                        @if (!base.IsLoading)
                        {
                            <span>@_weekStart.ToString("ddd d MMM") – @_weekEnd.ToString("ddd d MMM yyyy")</span>
                        }
                        else
                        {
                            <span>&nbsp;</span>
                        }
                    </div>
                </div>
            </div>
            <div class="header-right">
                <StatusBadge statusEnum="_jobTypeEnum" OnClick="@(() => SwapJobType())" />
                <div class="header-controls">
                    <div class="d-flex flex-row gap-2 align-content-center">
                        <ButtonIcon Icon="bi bi-arrow-left" Title="Previous week" OnClick="PreviousWeek" />
                        <ButtonIcon Icon="bi bi-arrow-right" Title="Next week" OnClick="NextWeek" />
                    </div>
                </div>
            </div>
        </Content>
    </PageHeader>

    @if (!base.IsLoading)
    {
        <div class="week-grid">
            @for (int i = 0; i < 5; i++)
            {
                DateOnly day = _weekStart.AddDays(i);
                List<WeeklyScheduleDto> items = GetItemsForDay(day);

                <ScheduleWeekDay Day="day" Items="items" JobType="(JobTypeEnum)_jobTypeEnum"  OnUpdate="LoadWeek"/>
            }
        </div>
    }
</div>

<style>
    .header-left {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .header-content {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        min-width: 280px;
    }

        .header-content h1 {
            color: var(--color-primary);
            font-size: 1.75rem;
            font-weight: 900;
            margin: 0;
        }

    .header-info {
        color: #64748b;
        font-size: 0.9rem;
    }

    .header-right {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .header-controls {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .week-grid {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 0.5rem;
        margin-top: 1rem;
    }

    @@media (max-width: 900px) {
        .week-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 500px) {
        .week-grid {
            grid-template-columns: 1fr;
        }

        .header-right {
            flex-direction: column;
        }
    }
</style>
