@page "/schedule/{date}/{jobType:int}";
@page "/schedule";
@using Portal.Client.Components.ScheduleComponents
@using Portal.Shared
@using Portal.Shared.DTO.Schedule
@using Portal.Shared.DTO.User
@inherits BaseDataComponent;

<PageTitle>Schedule - PRS Portal</PageTitle>
<div class="container">
    <!-- Header -->
    <PageHeader>
        <Content>
            <div class="header-left">
                <div class="header-content">
                    @if (!base.IsLoading)
                    {
                        <h1>
                            Schedule -
                            @_jobTypeEnum.GetDisplayName()
                        </h1>
                        <div class="header-info">
                            <span>@_dateTime.ToString("dddd, MMMM d, yyyy")</span>
                        </div>
                    }
                </div>
            </div>
            <div class="header-right">
                <StatusBadge statusEnum="_jobTypeEnum" OnClick="@(() => SwapJobType())" />

                <MudDatePicker T="DateTime?" Date="@((DateTime?)_dateTime)" Label="Select Date" Variant="Variant.Outlined"
                               Class="mt-0 mb-0" DateChanged="@((x) => ReloadCalendar(DateOnly.FromDateTime(x!.Value)))" IconSize="Size.Small" />
                <div class="d-flex flex-row gap-2">
                    <ButtonIcon Icon="bi bi-arrow-left" Title="Edit" OnClick="@(() => _dateTime = _dateTime.AddDays(-1))" />
                    <ButtonIcon Icon="bi bi-arrow-right" Title="Edit" OnClick="@(() => _dateTime = _dateTime.AddDays(1))" />
                </div>
            </div>
        </Content>
    </PageHeader>

    @if (!base.IsLoading)
    {
        <div class="scheduler-container">
            @foreach (ScheduleTrackDtoWithCalendar slot in _scheduleSlots)
            {
                <ViewScheduleTrack Track="slot" Users="_users" JobTypeId="JobType ?? 0" OnUpdate="LoadSchedule" />
            }
        </div>
    }
    else
    {
        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="400px" />
    }
    <div class="d-flex justify-content-center mt-4">
        <ButtonIcon Icon="bi bi-plus" OnClick="@(() => NewTrack())"/>
    </div>
</div>

<style>

    .header-left {
        display: flex;
        align-items: center;
        gap: 1rem;
        justify-content: center;
    }

    .header-content {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        min-width: 300px;
    }

        .header-content h1 {
            color: var(--color-primary);
            font-size: 1.75rem;
            font-weight: 900;
            margin: 0;
        }

    .header-info {
        display: flex;
        gap: 2rem;
        color: #64748b;
        font-size: 0.9rem;
    }

    .header-right {
        display: flex;
        align-items: center;
        gap: 1rem;
        min-width: 500px;
        justify-content: space-between;
        align-items: center;
    }


    .header-actions {
        display: flex;
        gap: 0.5rem;
    }

    .schedule-track-actions {
        display: flex;
        flex-direction: row;
        gap: var(--padding);
    }

    @@media (max-width: 1200px) {
        .schedule-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 1rem;
        }

        .header-left {
            width: 100%;
        }

        .header-right {
            width: 100%;
            justify-content: space-between;
            flex-wrap: wrap;
        }

        .header-controls {
            flex-wrap: wrap;
        }
    }

    @@media (max-width: 768px) {
        .schedule-header {
            padding: 1rem;
        }

        .header-content h1 {
            font-size: 1.5rem;
        }

        .header-info {
            font-size: 0.85rem;
        }

        .header-right {
            flex-direction: column;
            align-items: flex-start;
            gap: 0.75rem;
        }

        .header-controls {
            width: 100%;
            flex-direction: column;
            align-items: stretch;
        }

            .header-controls .mud-input-control {
                width: 100%;
            }

            .header-controls .mud-button {
                width: 100%;
            }

        .header-actions {
            width: 100%;
            justify-content: flex-start;
        }
    }

    @@media (max-width: 480px) {
        .header-content h1 {
            font-size: 1.25rem;
        }

        .btn-icon {
            width: 32px;
            height: 32px;
        }
    }

    .btn-icon {
        width: 36px;
        height: 36px;
        border: none;
        background: #f1f5f9;
        border-radius: 8px;
        cursor: pointer;
        font-size: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.2s;
        color: #64748b;
    }

        .btn-icon:hover {
            background: #e2e8f0;
        }

    .scheduler-container {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        grid-gap: 15px;
    }

    .schedule-users {
        height: fit-content;
        min-height: 100px;
        background: var(--color-white);
        padding: 1rem;
        border-radius: var(--border-rad);
        margin-bottom: 0.5rem;
    }

    .schedule-items {
        width: 100%;
        height: 100%;
        padding: 5px;
        overflow: scroll !important;
        border-radius: 8px;
        border: 1px solid var(--color-grey);
    }

    @@media (max-width: 1200px) {
        .scheduler-container {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    @@media (max-width: 1000px) {
        .scheduler-container {
            grid-template-columns: repeat(2, 1fr);
        }
    }
    @@media (max-width: 800px) {
        .scheduler-container {
            grid-template-columns: repeat(1, 1fr);
        }
    }
</style>