@page "/schedule/{date}/{jobType:int}";
@page "/schedule";
@using Portal.Client.Components.ScheduleComponents
@using Portal.Shared
@using Portal.Shared.DTO.Schedule
@using Portal.Shared.DTO.User
@using Portal.Shared.Helpers
@inherits BaseDataComponent;

<PageTitle>Schedule - PRS Portal</PageTitle>

<div class="wide-container">
    <!-- Header -->
    <PageHeader>
        <Content>
            <div class="header-left">
                <div class="header-content">
                    @if (!base.IsLoading)
                    {
                        <h1>
                            Schedule -
                            @_jobTypeEnum.GetDisplayName()
                        </h1>
                        <div class="header-info">
                            <span><a class="prs-link" title="View Week" href=@($"week/{_dateTime.ToString("yyyy-MM-dd")}/{(int)_jobTypeEnum}")>@_dateTime.ToString("dddd, MMMM d, yyyy")</a></span>
                        </div>
                    }
                </div>
            </div>
            <div class="header-right">
                <StatusBadge SingleStatus="_jobTypeEnum" OnClick="@(() => SwapJobType())" />

                <MudDatePicker T="DateTime?" Date="@((DateTime?)_dateTime)" Label="Select Date" Variant="Variant.Outlined"
                               Class="mt-0 mb-0" DateChanged="@((x) => ReloadCalendar(DateOnly.FromDateTime(x!.Value)))" IconSize="Size.Small" />
                <div class="d-flex flex-row gap-2">
                    <ButtonIcon Icon="bi bi-arrow-left" Title="Edit" OnClick="@(() => _dateTime = _dateTime.AddDays(-1))" />
                    <ButtonIcon Icon="bi bi-arrow-right" Title="Edit" OnClick="@(() => _dateTime = _dateTime.AddDays(1))" />
                </div>
            </div>
        </Content>
    </PageHeader>

    <Card>
        <ChildContent>
            <div class="page-container">
                @if (!base.IsLoading)
                {
                    <div class="scheduler-container">
                        <div class="hours-side border-rad shadow">
                            @* One row per hour slot (6am–5pm); bottom of column is 6pm — matches DayViewCalendar 12×60px *@
                            @for (int h = 6; h < 19; h++)
                            {
                                <div class="day-view-time-row">
                                    <span class="day-view-time-label">@DateTimeBuilder.FormatHour(h)</span>
                                </div>
                            }
                            @* <span class="day-view-time-label hours-6pm-label">@DateTimeBuilder.FormatHour(19)</span> *@
                        </div>
                        @foreach (ScheduleTrackDtoWithCalendar slot in _scheduleSlots)
                        {
                            <ViewScheduleTrack Track="slot" Users="_users" JobTypeId="JobType ?? 0" OnUpdate="LoadSchedule" />
                        }
                    </div>
                }
                else
                {
                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="800px" />
                }
            </div>
        </ChildContent>
    </Card>
    <div class="d-flex justify-content-center mt-4">
        <ButtonIcon Icon="bi bi-plus" OnClick="@(() => NewTrack())" />
    </div>
</div>

<style>

    .header-left {
        display: flex;
        align-items: center;
        gap: 1rem;
        justify-content: center;
    }

    .header-content {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        min-width: 300px;
    }

        .header-content h1 {
            color: var(--color-primary);
            font-size: 1.75rem;
            font-weight: 900;
            margin: 0;
        }

    .header-info {
        display: flex;
        gap: 2rem;
        color: #64748b;
        font-size: 0.9rem;
    }

    .header-right {
        display: flex;
        align-items: center;
        gap: 1rem;
        min-width: 500px;
        justify-content: space-between;
        align-items: center;
    }


    .header-actions {
        display: flex;
        gap: 0.5rem;
    }

    .schedule-track-actions {
        display: flex;
        flex-direction: row;
        gap: var(--padding);
    }

    @@media (max-width: 1200px) {
        .schedule-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 1rem;
        }

        .header-left {
            width: 100%;
        }

        .header-right {
            width: 100%;
            justify-content: space-between;
            flex-wrap: wrap;
        }

        .header-controls {
            flex-wrap: wrap;
        }
    }

    @@media (max-width: 768px) {
        .schedule-header {
            padding: 1rem;
        }

        .header-content h1 {
            font-size: 1.5rem;
        }

        .header-info {
            font-size: 0.85rem;
        }

        .header-right {
            flex-direction: column;
            gap: 0.75rem;
            width: unset;
        }

        .header-controls {
            width: 100%;
            flex-direction: column;
            align-items: stretch;
        }

            .header-controls .mud-input-control {
                width: 100%;
            }

            .header-controls .mud-button {
                width: 100%;
            }

        .header-actions {
            width: 100%;
            justify-content: flex-start;
        }
    }

    @@media (max-width: 480px) {
        .header-content h1 {
            font-size: 1.25rem;
        }

    }

    .scheduler-container {
        display: flex;
        flex-direction: row;
        flex-wrap: nowrap;
        gap: 10px;
        overflow-x: auto;
        overflow-y: hidden;
        padding-bottom: 8px;
        min-height: 0;
    }

        .scheduler-container .track-container {
            flex: 0 0 auto;
            min-width: 320px;
            max-width: 380px;
        }

    .schedule-users {
        height: fit-content;
        min-height: 100px;
        background: var(--color-white);
        padding: 1rem;
        border-radius: var(--border-rad);
        margin-bottom: 0.5rem;
    }

    .schedule-items {
        width: 100%;
        height: 100%;
        padding: 5px;
        overflow: scroll !important;
        border-radius: 8px;
        border: 1px solid var(--color-grey);
    }

    .hours-side {
        margin-top: 119px;
        flex: 0 0 48px;
        display: flex;
        flex-direction: column;
        border: 1px solid #e2e8f0;
        background: #f8fafc;
        position: sticky;
        left: 5px;
        z-index: 100;
        align-self: flex-start;
        height: 780px;
        box-sizing: border-box;
    }

    .hours-6pm-label {
        position: absolute;
        left: 4px;
        bottom: 2px;
        font-size: 0.7rem;
        color: #64748b;
        pointer-events: none;
    }

    .day-view-time-row {
        display: flex;
        align-items: flex-start;
        padding-top: 2px;
        box-sizing: border-box;
        border-bottom: 1px solid #e2e8f0;
        min-height: 60px !important;
    }

    .day-view-time-label {
        font-size: 0.7rem;
        color: #64748b;
        padding-left: 4px;
    }
    @@media (max-width: 1200px) {

    }

    @@media (max-width: 1000px) {
    }

    @@media (max-width: 800px) {
        .scheduler-container .track-container {
            min-width: 280px;
        }
    }
</style>