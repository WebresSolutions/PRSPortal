@page "/jobs/{JobId:int}"
@inherits BaseDataComponent

<PageTitle>Job @(_job?.JobNumber) - PRS Portal</PageTitle>

@if (IsLoading)
{
    <Spinner />
}
else if (_job is null)
{
    <div class="container">
        <div class="error-message">Job not found</div>
    </div>
}
else
{
    <div class="job-detail-container">
        <JobStatusProgress Statuses="@_job.JobTypeStatusDtos" CurrentStatusId="@_job.JobStatusId" />
        <!-- Header -->
        <PageHeader>
            <Content>
                <div class="job-header">
                    <div class="header-left">
                        <h1>Job <span class="colour-secondary">#@_job.JobNumber</span></h1>
                        <div class="header-info">
                            <span>@_job.Address?.ToDisplayString()</span>
                        </div>
                    </div>
                    <div class="header-right">
                        <StatusBadge StatusEnums="@_job.JobType" />
                        <div class="header-actions">
                            <ButtonIcon Icon="bi bi-pencil" Title="Edit" Href=@($"/jobs/edit/{JobId}") />
                        </div>
                    </div>
                </div>
            </Content>
        </PageHeader>

        <!-- Main Grid -->
        <div class="main-grid">
            <!-- Left Sidebar -->
            <div class="sidebar">
                <!-- Quick Stats -->
                <Card Title="Overview">
                    <ChildContent>
                        <div class="stats-mini">
                            <div class="stat-mini">
                                <div class="stat-mini-value">@_job.TaskCount</div>
                                <div class="stat-mini-label">Tasks</div>
                            </div>
                            <div class="stat-mini">
                                <div class="stat-mini-value">@_job.SiteVisitCount</div>
                                <div class="stat-mini-label">Site Visits</div>
                            </div>
                            <div class="stat-mini">
                                <div class="stat-mini-value">@_job.NoteCount</div>
                                <div class="stat-mini-label">Notes</div>
                            </div>
                            <div class="stat-mini">
                                <div class="stat-mini-value">@_job.ContactCount</div>
                                <div class="stat-mini-label">Contacts</div>
                            </div>
                        </div>
                    </ChildContent>
                </Card>
                <!-- Job Info -->
                <JobInfo Job="@_job" />
                @if (_job.Address?.LatLng is not null)
                {
                    @* <Card Title="Map">
                        <ChildContent>
                            <AdvancedGoogleMap @ref="@_map" Id="map1" Options="@_mapOptions" CssClass="border-rad" Height="300px">
                                @foreach (MarkerData marker in _markers)
                                {
                                    <MarkerComponent @key="marker.Id"
                                                     Lat="@marker.Lat"
                                                     Lng="@marker.Lng"
                                                     Clickable="@marker.Clickable"
                                                     Draggable="@marker.Draggable"
                                                     OnClick="@(() => marker.Active = !marker.Active)">
                                        <div class="custom-marker border-rad">
                                            <b>@marker.Title</b>
                                        </div>
                                    </MarkerComponent>
                                }
                            </AdvancedGoogleMap>
                        </ChildContent>
                    </Card> *@
                }
                <Portal.Client.Components.Files.ViewFiles JobId="JobId" Files="_job.JobFiles" OnFilesEdited="LoadJobData" />

                <JobTimeSheets TimeSheetsList="_job.TimeSheets" Job="_job" OnSaved="LoadJobData" />

                <!-- Quick Actions -->
                <Card Title="Quick Actions">
                    <ChildContent>
                        <div class="quick-actions">
                            <button class="quick-action-btn">+ Add Technical Contact</button>
                            <button class="quick-action-btn">+ Add Task</button>
                            <button class="quick-action-btn">+ Add Invoice</button>
                            <button class="quick-action-btn">+ Add Site Visit</button>
                            <button class="quick-action-btn">+ Add Note</button>
                        </div>
                    </ChildContent>
                </Card>
            </div>

            <div class="main-content">
                <!-- Right Sidebar -->
                <div class="visits-invoices">
                    <!-- Files-->
                    <!-- Site Visits -->
                    <JobSiteVisits SiteVisits="_job.SiteVisits" OnAdd="HandleAddSiteVisit" JobType="@_job.JobType.First()" />
                    <!-- Invoices -->
                    <Card HeaderTitle="Invoices" ShowHeaderWithTabs="true" Tabs="[TabTypeEnum.All, TabTypeEnum.Unsent, TabTypeEnum.Unpaid, TabTypeEnum.Overdue, TabTypeEnum.Deleted]">
                        <ChildContent>
                            <table class="table">
                                <thead>
                                    <tr>
                                        <th>Number</th>
                                        <th>Contact</th>
                                        <th>Total Price</th>
                                        <th>Created Date</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (_dummyData.Invoices.Count == 0)
                                    {
                                        <tr>
                                            <td colspan="5" class="empty-state">No records</td>
                                        </tr>
                                    }
                                    else
                                    {
                                        @foreach (var invoice in _dummyData.Invoices)
                                        {
                                            <tr>
                                                <td>@invoice.Number</td>
                                                <td>@invoice.Contact</td>
                                                <td>@invoice.TotalPrice</td>
                                                <td>@invoice.CreatedDate</td>
                                                <td>
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </ChildContent>
                    </Card>
                    <!-- Notes -->
                </div>
                <div class="other-content">
                    <JobNotes JobId="JobId" />
                    <!-- Technical Contacts -->
                    <div class="tech-contacts">
                        <TechnicalContacts JobId="JobId" />
                        <Card Title="Activity">
                            <ChildContent>
                                <div class="activity-list">
                                    <div class="activity-item border-grey">
                                        <div class="activity-title">Last Modified</div>
                                        <div class="activity-time">@_job.LastModified?.ModifiedOn.ToLocalDateTimeString()</div>
                                    </div>
                                    <div class="activity-item border-grey">
                                        <div class="activity-title">Modified By</div>
                                        <div class="activity-time">@_job.LastModifiedBy</div>
                                    </div>
                                </div>
                            </ChildContent>
                        </Card>
                    </div>
                </div>
                <!-- Tasks -->
                @* <Card HeaderTitle="Tasks" ShowHeaderWithTabs="true" Tabs="[TabTypeEnum.All, TabTypeEnum.Active, TabTypeEnum.ToInvoice, TabTypeEnum.Deleted]">
                        <ChildContent>
                            <table class="table">
                                <thead>
                                    <tr>
                                        <th>Task</th>
                                        <th>Quoted Price</th>
                                        <th>Active Date</th>
                                        <th>Completed Date</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (_job.Tasks.Count == 0)
                                    {
                                        <tr>
                                            <td colspan="5" class="empty-state">No records</td>
                                        </tr>
                                    }
                                    else
                                    {
                                        @foreach (var task in _job.Tasks)
                                        {
                                            <tr>
                                                <td>@task.InvoiceRequired</td>
                                                <td>@(task.QuotedPrice is null ? "" : task.QuotedPrice.Value)</td>
                                                <td>@task.ActiveDate.ToString("dd/MM/yyyy")</td>
                                                <td>@task.CompletedDate.ToString("dd/MM/yyyy")</td>
                                                <td>
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </ChildContent>
                    </Card>
 *@


                @*  <!-- Checklist -->
                    <Card Title="Checklist">
                        <ChildContent>
                            <table class="table">
                                <thead>
                                    <tr>
                                        <th>Item</th>
                                        <th>Site Work</th>
                                        <th>Checked</th>
                                        <th>Sent</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in _dummyData.ChecklistItems)
                                    {
                                        <tr>
                                            <td>@item.Name</td>
                                            <td>
                                                <select class="select-small">
                                                    <option>Not Completed</option>
                                                    <option>Completed</option>
                                                </select>
                                            </td>
                                            <td><input type="checkbox" checked="@item.Checked" /></td>
                                            <td><input type="checkbox" checked="@item.Sent" /></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </ChildContent>
                    </Card> *@

                <!-- Recent Activity -->

            </div>
        </div>
    </div>
}
