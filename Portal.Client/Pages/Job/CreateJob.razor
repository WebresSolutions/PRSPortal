@page "/jobs/create"
@inherits BaseDataComponent
@using GoogleMapsComponents
@using GoogleMapsComponents.Maps
@using Portal.Shared
@using Portal.Shared.DTO.Contact
@using Portal.Shared.DTO.Job
@using Portal.Shared.DTO.Address
@using Portal.Shared.Helpers

<PageTitle>Create Job - PRS Portal</PageTitle>

<div class="container">
    <PageHeader>
        <Content>
            <div style="min-width: 150px">
                <h2>Create New Job</h2>
            </div>
            <div>
                <ButtonIcon Href="/jobs" Icon="bi bi-sign-turn-left" />
            </div>
        </Content>
    </PageHeader>

    <Card>
        <ChildContent>
            @if (base.IsLoading)
            {
                <MudSkeleton Height="600px;" />
            }
            else
            {
                <EditForm Model="@Model" OnValidSubmit="@SubmitAsync" class="create-job-form">
                    <DataAnnotationsValidator />
                    <ValidationSummary />
                    <div class="form-grid">
                        <div>
                            <h3 class="form-section-title border-bottom pb-2">Job Details</h3>
                            <div class="form-sections border-rad">
                                <MudNumericField T="int" @bind-Value="Model.JobNumber" Label="Job Number" Variant="Variant.Outlined"
                                                 Required="true" RequiredError="Job number is required" Class="mb-3" For="@(() => Model.JobNumber)" />
                                <MudTextField @bind-Value="Model.Details" Label="Description" Variant="Variant.Outlined" Class="mb-3"
                                              For="@(() => Model.Details)" Counter="2000" Lines="3" />
                                <MudSelect T="JobTypeEnum" @bind-Value="Model.JobType" Label="Job Type" Variant="Variant.Outlined" Class="mb-3" For="@(() => Model.JobType)" Required="true">
                                    <MudSelectItem T="JobTypeEnum" Value="JobTypeEnum.Construction">@JobTypeEnum.Construction.GetDisplayName()</MudSelectItem>
                                    <MudSelectItem T="JobTypeEnum" Value="JobTypeEnum.Surveying">@JobTypeEnum.Surveying.GetDisplayName()</MudSelectItem>
                                </MudSelect>
                                <MudAutocomplete T="ListContactDto" Label="Contact" Value="JobContact" ValueChanged="OnContactChanged" Clearable="true" Variant="Variant.Outlined" DebounceInterval="100"
                                                 SearchFunc="@SearchContacts" ToStringFunc="@(e=> e is null ? null : $"{e.FullName} ({e.Email}) ({e.Phone})")" MaxItems="50" Required="true">
                                    <MoreItemsTemplate>
                                        <div class="d-flex justify-content-center">
                                            <small>
                                                Only the first 10 items are shown
                                            </small>
                                        </div>
                                    </MoreItemsTemplate>
                                </MudAutocomplete>
                                <MudSelect T="int?" @bind-Value="Model.CouncilId" Label="Council (optional)" Variant="Variant.Outlined" Clearable="true" Class="mb-3" For="@(() => Model.CouncilId)">
                                    @foreach (var c in Councils)
                                    {
                                        <MudSelectItem T="int?" Value="@c.CouncilId">@c.CouncilName</MudSelectItem>
                                    }
                                </MudSelect>
                                <MudNumericField T="int?" @bind-Value="Model.JobColourId" Label="Job Colour ID (optional)" Variant="Variant.Outlined" Min="1" Class="mb-3" Clearable="true" For="@(() => Model.JobColourId)" />
                            </div>
                        </div>

                        @if (Model.Address is not null && Model.Address.LatLng is not null)
                        {
                            <EditAddress Address="Model.Address" />
                        }


                        <div class="form-actions">
                            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Disabled="Submitting" StartIcon="@Icons.Material.Filled.Save">Create Job</MudButton>
                            <MudButton Variant="Variant.Outlined" Href="/jobs">Cancel</MudButton>
                        </div>
                    </div>
                </EditForm>
            }
        </ChildContent>
    </Card>
</div>

<style>
    .create-job-form {
        margin: 0;
    }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: calc(2 * var(--padding));
        align-items: start;
    }


    .form-sections {
        display: flex;
        flex-direction: column;
        gap: var(--padding);
        padding: var(--padding);
        background-color: var(--color-light-grey);
    }

    .form-lat-lng {
        display: flex;
        gap: var(--padding);
    }

    @@media (max-width: 900px) {
        .form-grid {
            grid-template-columns: 1fr;
        }
    }

    .form-section-title {
        font-size: 1rem;
        margin: 1rem 0 0.5rem;
    }

    .form-actions {
        display: flex;
        gap: 0.5rem;
        margin-top: 1.5rem;
    }

    .map-hint {
        font-size: 0.875rem;
        color: var(--mud-palette-text-secondary);
        margin-bottom: 0.5rem;
    }
</style>
