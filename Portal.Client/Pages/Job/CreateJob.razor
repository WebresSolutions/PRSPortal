@page "/jobs/create"
@inherits BaseDataComponent
@using GoogleMapsComponents
@using GoogleMapsComponents.Maps
@using Portal.Client.Components.JobComponents
@using Portal.Shared
@using Portal.Shared.DTO.Address
@using Portal.Shared.DTO.Contact
@using Portal.Shared.DTO.Job
@using Portal.Shared.DTO.User
@using Portal.Shared.DataEnums
@using Portal.Shared.Helpers

<PageTitle>Create Job - PRS Portal</PageTitle>

<div class="container">
    <PageHeader>
        <Content>
            <div style="min-width: 150px">
                <h2>Create New Job</h2>
            </div>
        </Content>
    </PageHeader>

    <Card>
        <ChildContent>
            @if (base.IsLoading)
            {
                <MudSkeleton Height="600px;" />
            }
            else
            {
                <EditForm Model="@_model" class="create-job-form" OnValidSubmit="SubmitAsync">
                    <DataAnnotationsValidator />
                    <ValidationSummary />
                    <div class="form-grid">
                        <div>
                            <h3 class="form-section-title border-bottom pb-2">Job Details</h3>
                            <div class="form-sections border-rad border-grey">
                               
                                <div>
                                    <label for="job-type">Job Type</label>
                                    <MudSelect name="job-type" T="JobTypeEnum"
                                               SelectedValues="_jobtypes"
                                               Variant="Variant.Outlined" Class=""
                                               Required="true" MultiSelection="true">
                                        <MudSelectItem T="JobTypeEnum" Value="JobTypeEnum.Construction">@JobTypeEnum.Construction.GetDisplayName()</MudSelectItem>
                                        <MudSelectItem T="JobTypeEnum" Value="JobTypeEnum.Surveying">@JobTypeEnum.Surveying.GetDisplayName()</MudSelectItem>
                                    </MudSelect>
                                    <ValidationMessage For="@(() => _model.JobType)" />
                                </div>
                                <div>
                                    <label for="responsible-user">Responsible Team Member</label>
                                    <MudSelect T="int?" MultiSelection="false" Variant="Variant.Outlined" Clearable="true"
                                               @bind-Value="_model.ResponsibleTeamMember">
                                        @foreach (UserDto user in _users)
                                        {
                                            <MudSelectItem T="int?" Value="@user.userId">@user.displayName</MudSelectItem>
                                        }
                                    </MudSelect>
                                </div>
                                <div>
                                    <label for="job-contact">Contact</label>
                                    <ContactAutocomplete Name="job-contact" Value="_jobContact" ValueChanged="OnContactChanged"
                                                         Clearable="true" Required="true" />
                                    <ValidationMessage For="@(() => _model.ContactId)" />
                                </div>

                                <div>
                                    <label for="job-council">Council</label>
                                    <MudSelect name="job-council" T="int?" @bind-Value="_model.CouncilId" Variant="Variant.Outlined" Clearable="true" Class="mb-3" For="@(() => _model.CouncilId)">
                                        @foreach (var c in _councils)
                                        {
                                            <MudSelectItem T="int?" Value="@c.CouncilId">@c.CouncilName</MudSelectItem>
                                        }
                                    </MudSelect>
                                    <ValidationMessage For="@(() => _model.CouncilId)" />
                                </div>

                                <div>
                                    <label for="job-colour">Colour</label>
                                    <MudNumericField name="job-colour" T="int?" @bind-Value="_model.JobColourId" Variant="Variant.Outlined" Min="1" Class="mb-3" Clearable="true" For="@(() => _model.JobColourId)" />
                                    <ValidationMessage For="@(() => _model.JobColourId)" />
                                </div>
                                <div>
                                    <label for="target-delivery-date">Target Delivery Date</label>
                                    <MudDatePicker name="target-delivery-date" Clearable=true @bind-Value="_model.TargetDeliveryDate" Variant="Variant.Outlined" Class="" For="@(() => _model.TargetDeliveryDate)" />
                                    <ValidationMessage For="@(() => _model.TargetDeliveryDate)" />
                                </div>    
                                <div>
                                    <label for="latest-client-update">Latest Client Update</label>
                                    <MudDatePicker name="latest-client-update" Clearable=true @bind-Value="_model.LatestClientUpdate" Variant="Variant.Outlined" Class="" For="@(() => _model.LatestClientUpdate)" />
                                    <ValidationMessage For="@(() => _model.LatestClientUpdate)" />
                                </div>
                                <div>
                                    <label for="job-details">Details</label>
                                    <MudTextField name="job-details" @bind-Value="_model.Details" Variant="Variant.Outlined"
                                                  For="@(() => _model.Details)" Counter="2000" Lines="3" />
                                    <ValidationMessage For="@(() => _model.Details)" />
                                </div>

                            </div>
                        </div>

                        @if (_model.Address is not null && _model.Address.LatLng is not null)
                        {
                            <EditAddress Address="_model.Address" />
                        }

                    </div>
                    <div class="form-actions">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Success"
                                   StartIcon="@Icons.Material.Filled.Save"
                                   ButtonType="ButtonType.Submit">
                            Save
                        </MudButton>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Error"
                                   StartIcon="@Icons.Material.Filled.Close"
                                   Href="/jobs">
                            Close
                        </MudButton>
                    </div>
                </EditForm>
            }
        </ChildContent>
    </Card>
</div>

<style>
    .create-job-form {
        margin: 0;
    }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: calc(2 * var(--padding));
        align-items: start;
    }


    .form-sections {
        display: flex;
        flex-direction: column;
        gap: var(--padding);
        padding: calc(2 * var(--padding));
        background-color: var(--color-light-grey);
    }

    .form-lat-lng {
        display: flex;
        gap: var(--padding);
    }

    @@media (max-width: 900px) {
        .form-grid {
            grid-template-columns: 1fr;
        }
    }

    .form-section-title {
        font-size: 1rem;
        margin: 1rem 0 0.5rem;
    }

    .form-actions {
        display: flex;
        gap: 0.5rem;
        margin-top: 1.5rem;
        justify-content: center;
    }

    .map-hint {
        font-size: 0.875rem;
        color: var(--mud-palette-text-secondary);
        margin-bottom: 0.5rem;
    }
</style>
