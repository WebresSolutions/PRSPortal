@page "/jobs/edit/{JobId:int}"
@inherits BaseDataComponent
@using Portal.Client.Components.JobComponents
@using Portal.Client.Pages.Job
@using Portal.Shared
@using Portal.Shared.DTO.Contact
@using Portal.Shared.DTO.Councils
@using Portal.Shared.DTO.Job
<PageTitle>Edit Job - PRS Portal</PageTitle>

<div class="container">
    <PageHeader>
        <Content>
            <div class="" style="min-width: 150px">
                <h2>Edit Job</h2>
            </div>
            <ButtonIcon Href=@($"/jobs/view/{JobId}") Icon="bi bi-sign-turn-left" />
        </Content>
    </PageHeader>
    <Card>
        @if (base.IsLoading)
        {
            <MudSkeleton Height="600px;" />
        }
        else
        {
            @if (_model is not null)
            {
                <EditForm Model="@_model" OnValidSubmit="@SubmitAsync" class="create-job-form">
                    <div class="form-grid">
                        <div>
                            <h3 class="form-section-title border-bottom pb-2">Job Details</h3>
                            <div class="form-sections border-rad">
                                <MudNumericField T="int" @bind-Value="_model.JobNumber" Label="Job Number" Variant="Variant.Outlined"
                                                 Required="true" RequiredError="Job number is required" Class="" For="@(() => _model.JobNumber)" />
                                <MudTextField @bind-Value="_model.Details" Label="Details" Variant="Variant.Outlined" Class=""
                                              For="@(() => _model.Details)" Counter="2000" Lines="3" />
                                <MudSelect T="JobTypeEnum" @bind-Value="_model.JobType" Label="Job Type" Variant="Variant.Outlined" Class="" For="@(() => _model.JobType)" Required="true">
                                    <MudSelectItem T="JobTypeEnum" Value="JobTypeEnum.Construction">@JobTypeEnum.Construction.GetDisplayName()</MudSelectItem>
                                    <MudSelectItem T="JobTypeEnum" Value="JobTypeEnum.Surveying">@JobTypeEnum.Surveying.GetDisplayName()</MudSelectItem>
                                </MudSelect>
                                <MudAutocomplete T="ListContactDto" Label="Contact" Value="_jobContact" ValueChanged="OnContactChanged" Clearable="true" Variant="Variant.Outlined" DebounceInterval="100"
                                                 SearchFunc="@SearchContacts" ToStringFunc="@(e=> e is null ? null : $"{e.FullName} ({e.Email}) ({e.Phone})")" MaxItems="50" Required="true">
                                    <MoreItemsTemplate>
                                        <div class="d-flex justify-content-center">
                                            <small>
                                                Only the first 10 items are shown
                                            </small>
                                        </div>
                                    </MoreItemsTemplate>
                                </MudAutocomplete>
                                <MudSelect T="int?" @bind-Value="_model.CouncilId" Label="Council (optional)" Variant="Variant.Outlined" Clearable="true" Class="" For="@(() => _model.CouncilId)">
                                    @foreach (var c in _councils)
                                    {
                                        <MudSelectItem T="int?" Value="@c.CouncilId">@c.CouncilName</MudSelectItem>
                                    }
                                </MudSelect>
                                <MudNumericField T="int?" @bind-Value="_model.JobColourId" Label="Job Colour ID (optional)" Variant="Variant.Outlined" Min="1" Class="" Clearable="true" For="@(() => _model.JobColourId)" />
                            </div>
                        </div>

                        @if (_model.Address is not null)
                        {
                            <EditAddress Address="_model.Address" />
                        }


                        <div class="form-actions">
                            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Disabled="_isSubmitting" StartIcon="@Icons.Material.Filled.Save">Save Details</MudButton>
                            <MudButton Variant="Variant.Outlined" Href="/jobs">Cancel</MudButton>
                        </div>
                    </div>
                </EditForm>
            }
            @if (_model is null)
            {
                <small>Details not loaded</small>
            }
        }
    </Card>
</div>

@code {
    /// <summary>
    /// The Job id
    /// </summary>
    [Parameter]
    public int JobId { get; set; }
    /// <summary>
    /// If submitting
    /// </summary>
    private bool _isSubmitting;
    /// <summary>
    /// The model
    /// </summary>
    private JobDetailsDto? _model;
    /// <summary>
    /// The List of job contacts
    /// </summary>
    private ListContactDto? _jobContact;

    /// <summary>
    /// List of councils
    /// </summary>
    private CouncilPartialDto[] _councils = [];

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        await LoadJobData();
        Result<CouncilPartialDto[]>? councilResult = await _apiService.GetCouncils();
        if (councilResult?.IsSuccess == true && councilResult.Value is not null)
            _councils = councilResult.Value;
        if (_model is { PrimaryContact: not null })
        {
            _jobContact = new()
            {
                ContactId = _model.ContactId,
                FullName = _model.PrimaryContact.ContactName,
                Phone = _model.PrimaryContact.Phone
            };
        }
    }

    private async Task LoadJobData()
    {
        IsLoading = true;
        try
        {
            Result<JobDetailsDto>? result = await _apiService.Job(JobId);
            if (result is not null && result.IsSuccess && result.Value is not null)
            {
                _model = result.Value;
            }
            else
            {
                _snackbar?.Add("Error loading job details", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            _snackbar?.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task SubmitAsync()
    {
        if (_model!.JobNumber <= 0)
        {
            _snackbar?.Add("Job number must be greater than 0.", Severity.Warning);
            return;
        }

        _isSubmitting = true;
        try
        {
            Result<JobDetailsDto> result = await _apiService.UpdateJob(_model);
            if (result.IsSuccess && result.Value is not null)
            {
                _snackbar?.Add("Job created successfully.", Severity.Success);
                _navigationManager.NavigateTo($"/jobs/view/{result.Value.JobId}");
            }
            else
                _snackbar?.Add(result.ErrorDescription ?? "Failed to create job.", Severity.Error);
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private void OnContactChanged(ListContactDto? value)
    {
        _jobContact = value;
        _model!.ContactId = value?.ContactId ?? 0;
    }

    /// <summary>
    /// Used by the type ahead auto complete for searching contacts
    /// </summary>
    /// <param name="search">The search string</param>
    /// <param name="token">The token</param>
    /// <returns></returns>
    public async Task<IEnumerable<ListContactDto>> SearchContacts(string search, CancellationToken token)
    {
        Result<PagedResponse<ListContactDto>>? contactResult = await _apiService.GetAllContacts(500, 1, search, null, SortDirectionEnum.Asc);

        if (contactResult?.IsSuccess == true && contactResult.Value?.Result is not null)
            return contactResult.Value.Result;
        else
            return [];
    }
}

<style>

    .create-job-form {
        margin: 0;
    }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: calc(2 * var(--padding));
        align-items: start;
    }


    .form-sections {
        display: flex;
        flex-direction: column;
        gap: var(--padding);
        padding: calc(2 * var(--padding));
        background-color: var(--color-light-grey);
    }

    .form-lat-lng {
        display: flex;
        gap: var(--padding);
    }

    @@media (max-width: 900px) {
        .form-grid {
            grid-template-columns: 1fr;
        }
    }

    .form-section-title {
        font-size: 1rem;
        margin: 1rem 0 0.5rem;
    }

    .form-actions {
        display: flex;
        gap: 0.5rem;
        margin-top: 1.5rem;
    }

    .map-hint {
        font-size: 0.875rem;
        color: var(--mud-palette-text-secondary);
        margin-bottom: 0.5rem;
    }

    .border-rad {
        border-radius: 8px;
    }
</style>
