@page "/jobs/edit/{JobId:int}"
@inherits BaseDataComponent
@using Portal.Client.Components.JobComponents
@using Portal.Client.Pages.Job
@using Portal.Shared
@using Portal.Shared.DTO.Contact
@using Portal.Shared.DTO.Councils
@using Portal.Shared.DTO.Job
@using Portal.Shared.DTO.User
@using Portal.Shared.DataEnums
<PageTitle>Edit Job - PRS Portal</PageTitle>

<div class="container">
    <PageHeader>
        <Content>
            <div class="" style="min-width: 150px">
                <h2>Edit Job</h2>
            </div>
            <ButtonIcon Href=@($"/jobs/{JobId}") Icon="bi bi-sign-turn-left" />
        </Content>
    </PageHeader>
    @if (_model is not null && !base.IsLoading)
    {
        <JobStatusProgress Statuses="@_JobTypeStatusDtos" CurrentStatusId="@_model.JobStatusId" />
    }
    <Card>
        @if (base.IsLoading)
        {
            <MudSkeleton Height="600px;" />
        }
        else
        {
            @if (_model is not null)
            {
                <EditForm Model="@_model" class="create-job-form" OnValidSubmit="SubmitAsync">
                    <DataAnnotationsValidator />
                    <ValidationSummary />
                    <div class="form-grid">
                        <div>
                            <h3 class="form-section-title border-bottom pb-2">Job Details</h3>
                            <div class="form-sections border-rad border-grey">
                                <div>
                                    <label for="job-type">Job Type</label>
                                    <MudSelect name="job-type" T="JobTypeEnum" 
                                               SelectedValues="_selectedJobtypes"
                                               SelectedValuesChanged="OnSelect"
                                               Variant="Variant.Outlined" Class=""
                                               Required="true" MultiSelection="true">
                                        @foreach (JobTypeEnum jobType in _jobtypes)
                                        {
                                            <MudSelectItem T="JobTypeEnum" Value="jobType">@jobType.GetDisplayName()</MudSelectItem>
                                        }
                                    </MudSelect>
                                    <ValidationMessage For="@(() => _model.JobTypes)" />
                                </div>

                                <div>
                                    <label for="job-status">Job status</label>
                                    <MudSelect id="job-status" name="job-status" T="int?"
                                               Value="_model.JobStatusId"
                                               ValueChanged="OnJobStatusIdChanged"
                                               Variant="Variant.Outlined"
                                               Clearable="true"
                                               Placeholder="Select status"
                                               For="@(() => _model.JobStatusId)"
                                               Disabled="@(_JobTypeStatusDtos.Length == 0)">
                                        @foreach (var s in _JobTypeStatusDtos.OrderBy(x => x.Sequence))
                                        {
                                            <MudSelectItem T="int?" Value="@s.Id">@s.Name</MudSelectItem>
                                        }
                                    </MudSelect>
                                    @if (_JobTypeStatusDtos.Length == 0)
                                    {
                                        <small class="text-muted d-block mt-1">No statuses are configured for this job's type(s).</small>
                                    }
                                </div>
                                <div>
                                    <label for="responsible-user">Responsible Team Member</label>
                                    <MudSelect T="int?" MultiSelection="false" Variant="Variant.Outlined" Clearable="true"  
                                               Value="_model.ResponsibleTeamMember" ValueChanged="@((x) => _model.ResponsibleTeamMember = x)" Placeholder="Select Responsible Team Member">
                                        @foreach (UserDto user in _users)
                                        {
                                            <MudSelectItem T="int?" Value="@user.userId">@user.displayName</MudSelectItem>
                                        }
                                    </MudSelect>
                                </div>
                                <div>
                                    <label for="job-contact">Contact</label>
                                    <MudAutocomplete name="job-contact" T="ListContactDto" Value="_jobContact" ValueChanged="OnContactChanged" Clearable="true" Variant="Variant.Outlined" DebounceInterval="100"
                                                     SearchFunc="@SearchContacts" ToStringFunc="@(e=> e.ToString())" MaxItems="50" Required="true">
                                        <MoreItemsTemplate>
                                            <div class="d-flex justify-content-center">
                                                <small>
                                                    Only the first 10 items are shown
                                                </small>
                                            </div>
                                        </MoreItemsTemplate>
                                    </MudAutocomplete>
                                    <ValidationMessage For="@(() => _model.ContactId)" />
                                </div>

                                <div>
                                    <label for="job-council">Council</label>
                                    <MudSelect name="job-council" T="int?" @bind-Value="_model.CouncilId" Variant="Variant.Outlined" Clearable="true" Class="" For="@(() => _model.CouncilId)">
                                        @foreach (var c in _councils)
                                        {
                                            <MudSelectItem T="int?" Value="@c.CouncilId">@c.CouncilName</MudSelectItem>
                                        }
                                    </MudSelect>
                                    <ValidationMessage For="@(() => _model.CouncilId)" />
                                </div>
                                <div>
                                    <label for="job-colour-id">Colour</label>
                                    <MudNumericField name="job-colour-id" T="int?" @bind-Value="_model.JobColourId" Variant="Variant.Outlined" Min="1" Class="" Clearable="true" For="@(() => _model.JobColourId)" />
                                    <ValidationMessage For="@(() => _model.JobColourId)" />
                                </div>

                                <div>
                                    <label for="details">Details</label>
                                    <MudTextField name="details" @bind-Value="_model.Details" Variant="Variant.Outlined" Class=""
                                                  For="@(() => _model.Details)" Counter="2000" Lines="3" />
                                    <ValidationMessage For="@(() => _model.Details)" />
                                </div>

                            </div>
                        </div>

                        @if (_model.Address is not null)
                        {
                            <EditAddress Address="_model.Address" />
                        }

                    </div>
                    <div class="form-actions">
                        <ButtonIcon Icon="bi bi-save-fill" CssClass="text-green" Text="Save" ButtonType="submit" />
                        <ButtonIcon Icon="bi bi-x-circle" CssClass="text-red" Href="/jobs" Text="Close" />
                    </div>
                </EditForm>
            }
            @if (_model is null)
            {
                <small>Details not loaded</small>
            }
        }
    </Card>
</div>



<style>

    .create-job-form {
        margin: 0;
    }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: calc(2 * var(--padding));
        align-items: start;
    }


    .form-sections {
        display: flex;
        flex-direction: column;
        gap: var(--padding);
        padding: calc(2 * var(--padding));
        background-color: var(--color-light-grey);
    }

    .form-lat-lng {
        display: flex;
        gap: var(--padding);
    }

    @@media (max-width: 900px) {
        .form-grid {
            grid-template-columns: 1fr;
        }
    }

    .form-section-title {
        font-size: 1rem;
        margin: 1rem 0 0.5rem;
    }

    .form-actions {
        display: flex;
        gap: 0.5rem;
        margin-top: 1.5rem;
        justify-content: center;
    }

    .map-hint {
        font-size: 0.875rem;
        color: var(--mud-palette-text-secondary);
        margin-bottom: 0.5rem;
    }

    .border-rad {
        border-radius: 8px;
    }
</style>