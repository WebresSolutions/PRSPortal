@inherits BaseDataComponent;
@using Portal.Shared
@using Portal.Shared.DTO.Contact
@using Portal.Shared.DTO.Job
@using Portal.Shared.ResponseModels
@using Portal.Shared.Web

@page "/jobs"

<div class="container">
    <PageHeader>
        <Content>
            <div class="" style="min-width: 150px">
                <h2>Jobs</h2>
                <div>
                    <ButtonIcon Icon="bi bi-plus" Title="Delete" CssClass="text-green" Href="/jobs/create" Text="New">
                    </ButtonIcon>
                </div>
            </div>
            <div class="search-container">
                <MudTextField T="string" @bind-Value="_sessionData.AddressSearch" Placeholder="Search by Address" Adornment="Adornment.Start" TextChanged="(async (x) => { _sessionData.AddressSearch = x; await OnSearch(x); })" Variant="Variant.Outlined"
                              AdornmentIcon="@Icons.Material.Filled.OtherHouses" IconSize="Size.Medium" Class="" Clearable="true" OnClearButtonClick="@(() => _sessionData.AddressSearch = null)"></MudTextField>
                <MudTextField T="string" @bind-Value="_sessionData.JobNumberSearch" Placeholder="Search by Job Number" Adornment="Adornment.Start" TextChanged="(async (x) => { _sessionData.JobNumberSearch = x; await OnSearch(x);})" Variant="Variant.Outlined"
                              AdornmentIcon="@Icons.Material.Filled.Numbers" IconSize="Size.Medium" Class="" Clearable="true" OnClearButtonClick="@(() => _sessionData.JobNumberSearch = null)"></MudTextField>
                <MudTextField T="string" @bind-Value="_sessionData.ContactSearch" Placeholder="Search by Contact" Adornment="Adornment.Start" TextChanged="(async (x) => { _sessionData.ContactSearch = x; await OnSearch(x);})" Variant="Variant.Outlined"
                              AdornmentIcon="@Icons.Material.Filled.Group" IconSize="Size.Medium" Class="" Clearable="true" OnClearButtonClick="@(() => _sessionData.ContactSearch = null)"></MudTextField>
            </div>
        </Content>
    </PageHeader>
    <Card>
        <ChildContent>
            <MudDataGrid T="ListJobDto"
                         ServerData="LoadJobs"
                         Filterable="true"
                         SortMode="SortMode.Single"
                         Loading="base.IsLoading"
                         RowsPerPage="_rowsPerPage"
                         CurrentPage="_sessionData.Page"
                         CurrentPageChanged="@((page) => { _sessionData.Page = page; SaveSessionData(); })"
                         Dense=true
                         @ref="_grid"
                         Striped="true">
                <Columns>
                    <TemplateColumn StickyLeft="true" Title="Action" HeaderStyle="max-width: 130px">
                        <CellTemplate>
                            <div class="d-flex flex-row gap-1">
                                <ButtonIcon Icon="bi bi-eye" Title="Edit" Href="@($"/jobs/view/{context.Item.JobId}")" />
                                <ButtonIcon Icon="bi bi-pencil" Title="Edit" Href="@($"/jobs/edit/{context.Item.JobId}")" />
                                <ButtonIcon Icon="bi bi-trash" Title="Delete" CssClass="text-red" OnClick="@(() => RemoveJob(context.Item.JobId))" />
                            </div>
                        </CellTemplate>
                    </TemplateColumn>
                    <PropertyColumn Property="x => x.JobNumber" ShowFilterIcon="false" Title="Job Number #" HeaderStyle="max-width: 75px" />
                    @* <PropertyColumn Property="x => x.JobId" ShowFilterIcon="false" HeaderStyle="max-width: 75px" /> *@
                    <TemplateColumn ShowFilterIcon="false" Title="Contact">
                        <CellTemplate>
                            <p>@(context.Item.JoinedContactName)</p>
                        </CellTemplate>
                    </TemplateColumn>
                    <PropertyColumn Property="x => x.Address.Street" ShowFilterIcon="false" Title="Street"/>
                    <PropertyColumn Property="x => x.Address.Suburb" ShowFilterIcon="false" Title="Suburb" />
                    <TemplateColumn ShowFilterIcon="false" Title="Job Type">
                        <CellTemplate>
                            <StatusBadge statusEnum="@((JobTypeEnum)context.Item.JobTypeInt)" />
                        </CellTemplate>
                    </TemplateColumn>
                </Columns>
                <PagerContent>
                    <MudDataGridPager T="ListJobDto" />
                </PagerContent>
            </MudDataGrid>
        </ChildContent>
    </Card>
</div>

<style>
</style>
