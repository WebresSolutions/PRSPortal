@page "/quotes/accept"
@attribute [AllowAnonymous]
@layout BareLayout

@using Microsoft.AspNetCore.Authorization
@using Portal.Shared.DataEnums
@using Portal.Shared.DTO.Quote
@using Portal.Shared.DTO.Quote.PartailQuote
@using Portal.Shared.ResponseModels
@using System.Globalization

<PageTitle>Fee proposal · @_pageQuoteRef</PageTitle>

<div class="container">
    @if (_isLoading)
    {
        <Spinner />
    }

    @if (_loadError is not null)
    {
        <Card>
            <ChildContent>
                <section class="error-section w-100">
                    <small>
                        Your link to view this quote has expired. Please check your inbox for a more recent link or contact <b>Peter Richards</b> for a new one.
                    </small>
                </section>
            </ChildContent>
        </Card>
    }

    @if (_quoteDetails is not null)
    {
        <div class="quote-detail-page quote-acceptance-page">
            <PageHeader>
                <Content>
                    <div class="quote-detail-header-title">

                        <h2 class="mb-1">Quote <span class="colour-secondary">#@_quoteDetails.QuoteRef</span></h2>
                        <p class="text-muted small mb-0">Fee Proposal</p>
                    </div>
                </Content>
            </PageHeader>
            @if (_quoteDetails.QuoteStatus is QuoteStatusEnum.Accepted or QuoteStatusEnum.Rejected)
            {
                <MudAlert Severity="@(_quoteDetails.QuoteStatus is QuoteStatusEnum.Accepted ? Severity.Success : Severity.Info)"
                          Class="my-3 border-rad"
                          Variant="Variant.Filled">
                    @if (_quoteDetails.QuoteStatus is QuoteStatusEnum.Accepted)
                    {
                        <text>Thank you — this fee proposal has been accepted. We will be in touch regarding next steps.</text>
                    }
                    else
                    {
                        <text>This fee proposal has been declined. If you have any questions, please contact us.</text>
                    }
                </MudAlert>
            }
            <div class="quote-container">
                <section class="d-flex flex-column gap-2">
                    <Card Title="Contact">
                        <ChildContent>
                            <div class="info-row">
                                <span class="info-label">Name</span>
                                <span class="info-value">@_quoteDetails.Contact.FullName</span>
                            </div>
                            <div class="info-row">
                                <span class="info-label">Phone</span>
                                <span class="info-value">
                                    @if (string.IsNullOrWhiteSpace(_quoteDetails.Contact.Phone))
                                    {
                                        <text>—</text>
                                    }
                                    else
                                    {
                                        <a class="prs-link" href="@($"tel:{_quoteDetails.Contact.Phone}")">@_quoteDetails.Contact.Phone</a>
                                    }
                                </span>
                            </div>
                            <div class="info-row">
                                <span class="info-label">Email</span>
                                <span class="info-value">
                                    @if (string.IsNullOrWhiteSpace(_quoteDetails.Contact.Email))
                                    {
                                        <text>—</text>
                                    }
                                    else
                                    {
                                        <a class="prs-link" href="@($"mailto:{_quoteDetails.Contact.Email}")">@_quoteDetails.Contact.Email</a>
                                    }
                                </span>
                            </div>
                        </ChildContent>
                    </Card>
                    <Card Title="Site Address">
                        <ChildContent>
                            @if (_quoteDetails.Address is { } a)
                            {
                                <div class="info-row">
                                    <span class="info-label">Street</span>
                                    <span class="info-value">@(string.IsNullOrWhiteSpace(a.Street) ? "—" : a.Street)</span>
                                </div>
                                <div class="info-row">
                                    <span class="info-label">Suburb</span>
                                    <span class="info-value">@a.Suburb</span>
                                </div>
                                <div class="info-row">
                                    <span class="info-label">State</span>
                                    <span class="info-value">@a.State</span>
                                </div>
                                <div class="info-row">
                                    <span class="info-label">Post Code</span>
                                    <span class="info-value">@a.PostCode</span>
                                </div>
                            }
                            else
                            {
                                <p class="text-muted small mb-0">No address on file.</p>
                            }
                        </ChildContent>
                    </Card>
                    @if (CanShowResponseActions)
                    {
                        <Card Title="Your response" CssClass="quote-acceptance-response-card">
                            <ChildContent>

                                <MudToggleGroup T="QuoteStatusEnum?" @bind-Value="_chosenStatus" Class="mb-4" @ValueChanged=@(() => ClearValues())>
                                    <MudToggleItem T="QuoteStatusEnum?" Value="@QuoteStatusEnum.Accepted" Text="Accept Quote" />
                                    <MudToggleItem T="QuoteStatusEnum?" Value="@QuoteStatusEnum.Rejected" Text="Reject Quote" />
                                </MudToggleGroup>
                                
                                @if (_chosenStatus is not null)
                                {
                                    @if (_chosenStatus is QuoteStatusEnum.Rejected)
                                    {
                                        <EditForm OnSubmit="SubmitRejectAsync" Model="_model">
                                            <div>
                                                <label>Reason for declining</label>
                                                <MudTextField @bind-Value="_model.ReasonForRejection"
                                                              Variant="Variant.Outlined"
                                                              Margin="Margin.Dense"
                                                              Lines="5"
                                                              Disabled="_isSubmitting"
                                                              HelperText="Required if you choose Reject" />
                                            </div>
                                            <div class="quote-acceptance-actions">
                                                <MudButton Variant="Variant.Filled"
                                                           Color="Color.Dark"
                                                           Class="quote-acceptance-btn-reject"
                                                           Disabled="_isSubmitting"
                                                           ButtonType="ButtonType.Submit">
                                                    Reject
                                                </MudButton>
                                            </div>
                                        </EditForm>
                                    }

                                    @if (_chosenStatus is QuoteStatusEnum.Accepted)
                                    {
                                
                                        <p class="text-muted small mb-3">
                                            Confirm the details below match what you expect, then accept or decline this fee proposal.
                                        </p>
                                        <EditForm OnSubmit="SubmitApproveAsync" Model="_model">
                                            <MudCheckBox T="bool" Color="Color.Primary" @bind-Value="_model.AddressIsCorrect" Label="The property address on this fee proposal is correct" Disabled="_isSubmitting" />
                                            <MudCheckBox T="bool" Color="Color.Primary" @bind-Value="_model.ContactDetailsAreCorrect" Label="The contact details above are correct" Disabled="_isSubmitting" />
                                            <div>
                                                <label>Signed Name</label>
                                                <MudTextField @bind-Value="_model.SignedName"
                                                              Variant="Variant.Outlined"
                                                              Margin="Margin.Dense"
                                                              Disabled="_isSubmitting"
                                                              HelperText="Shown on the acceptance record if you accept" Required="true" />
                                            </div>
                                   
                                            <div class="quote-acceptance-actions">

                                                <MudButton Variant="Variant.Filled"
                                                           Color="Color.Success"
                                                           Class="quote-acceptance-btn-approve"
                                                           Disabled="@(_isSubmitting || _model.SignedName.IsWhiteSpace() || !_model.AddressIsCorrect || !_model.ContactDetailsAreCorrect)"
                                                           StartIcon="@Icons.Material.Filled.Check"
                                                           ButtonType="ButtonType.Submit">
                                                    Approve
                                                </MudButton>
                                            </div>
                                        </EditForm>
                                    }
                                }
                            </ChildContent>
                        </Card>
                    }
                </section>
                <section>
                    <Card Title="Fees">
                        <ChildContent>
                            @if (_quoteDetails.LineItems.Length == 0)
                            {
                                <p class="text-muted small mb-0">No line items.</p>
                            }
                            else
                            {
                                <div class="quote-detail-lines border-rad border-grey overflow-hidden">
                                    <div class="quote-detail-lines-head d-none d-md-grid">
                                        <span>Service</span>
                                        <span>Description</span>
                                        <span class="text-md-end">Amount (+GST)</span>
                                    </div>
                                    @foreach (QuoteLineItemPartialDto line in _quoteDetails.LineItems)
                                    {
                                        <div class="quote-detail-line-row">
                                            <div>
                                                <span class="d-md-none text-muted small">Service</span>
                                                <span class="fw-semibold d-block">@line.Name</span>
                                            </div>
                                            <div>
                                                <span class="d-md-none text-muted small"></span>
                                                <span class="d-block"></span>
                                            </div>
                                            <div class="text-md-end fw-semibold">@line.Price.ToString("C", QuoteCurrencyCulture)</div>
                                        </div>
                                    }
                                    <div class="quote-detail-lines-total">
                                        <span class="fw-semibold">Total (ex. GST)</span>
                                        <span class="fw-semibold">@_quoteDetails.Total.ToString("C", QuoteCurrencyCulture)</span>
                                    </div>
                                </div>
                            }

                            <section class="mt-2 suggestions-section">
                                <small>
                                    Please note: This fee proposal remains valid until <b>@_quoteDetails.ValidUntilDate.ToString("dd/MM/yyyy").</b> If acceptance is received after this time,
                                    our fees may be reviewed and revised prior to commencement.
                                </small>
                            </section>
                        </ChildContent>
                    </Card>
                </section>
            </div>

           
        </div>
    }
</div>


