@page "/quotes/{QuoteId:int}"
@inherits BaseDataComponent
@using Portal.Shared.DataEnums
@using Portal.Shared.DTO.Quote
@using Portal.Shared.Helpers

<PageTitle>Quote @(_quote?.QuoteReference ?? QuoteId.ToString()) - PRS Portal</PageTitle>

@if (IsLoading)
{
    <div class="wide-container">
        <Spinner />
    </div>
}
else
{
    @if (_quote is not null)
    {
        <div class="wide-container quote-detail-page">
            <PageHeader>
                <Content>
                    <div class="quote-detail-header-title">
                        <h2 class="mb-1">Quote <span class="colour-secondary">#@_quote.QuoteReference</span></h2>
                        <p class="text-muted small mb-0">@_quote.Address!.ToDisplayString()</p>
                    </div>
                    <div class="quote-detail-header-aside">
                        <div class="quote-detail-header-toolbar">
                            <QuoteStatusBadge SingleStatus="_quote.QuotesStatus" />
                            @if (_quote.QuotesStatus.StatusEnum is (QuoteStatusEnum.Draft or QuoteStatusEnum.New or QuoteStatusEnum.Rejected))
                            {
                                <div class="quote-detail-header-actions">
                                    <MudButton Variant="Variant.Filled"
                                               Color="Color.Primary"
                                               Size="Size.Small"
                                               Class="quote-send-header-btn"
                                               StartIcon="@Icons.Material.Filled.Send"
                                               OnClick="@OnSendQuoteAsync"
                                                title="Send Quote">
                                        @(_quote.QuotesStatus.StatusEnum is QuoteStatusEnum.Rejected ? "Re-send to client" : "Send to client")
                                    </MudButton>
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                   title="Edit quote"
                                                   aria-label="Edit quote"
                                                   Href="@($"/quotes/edit/{QuoteId}")"
                                                   Color="Color.Secondary"
                                                   Variant="Variant.Filled"
                                                   Size="Size.Small"
                                                   Class="quote-header-edit-btn" />
                                </div>
                            }
                            else if(_quote.QuotesStatus.StatusEnum is QuoteStatusEnum.Sent)
                            {
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           Size="Size.Small"
                                           Class="quote-send-header-btn"
                                           StartIcon="@Icons.Material.Filled.Send"
                                           OnClick="@OnSendQuoteAsync"
                                           title="Send Quote">
                                    Re-Send to client
                                </MudButton>
                            }
                        </div>
                    </div>
                </Content>
            </PageHeader>
            <div class="quote-container">
                <section class="">
                    <div class="quote-contact-address">
                        <Card Title="Contact">
                            <ChildContent>
                                @if (_quote.Contact is { } c)
                                {
                                    <div class="info-row">
                                        <span class="info-label">Name</span>
                                        <span class="info-value">
                                            <a class="prs-link" href="@($"/contacts/{c.ContactId}")">@c.FullName</a>
                                        </span>
                                    </div>
                                    <div class="info-row">
                                        <span class="info-label">Phone</span>
                                        <span class="info-value">@(string.IsNullOrWhiteSpace(c.Phone) ? "—" : c.Phone)</span>
                                    </div>
                                    <div class="info-row">
                                        <span class="info-label">Email</span>
                                        <span class="info-value">@(string.IsNullOrWhiteSpace(c.Email) ? "—" : c.Email)</span>
                                    </div>
                                }
                                else
                                {
                                    <p class="text-muted small mb-0">No contact on file.</p>
                                }
                            </ChildContent>
                        </Card>
                        <Card Title="Site Address">
                            <ChildContent>
                                @if (_quote.Address is { } a)
                                {
                                    <div class="info-row">
                                        <span class="info-label">Street</span>
                                        <span class="info-value">@(string.IsNullOrWhiteSpace(a.Street) ? "—" : a.Street)</span>
                                    </div>
                                    <div class="info-row">
                                        <span class="info-label">Suburb</span>
                                        <span class="info-value">@a.Suburb</span>
                                    </div>
                                    <div class="info-row">
                                        <span class="info-label">State</span>
                                        <span class="info-value">@a.State</span>
                                    </div>
                                    <div class="info-row">
                                        <span class="info-label">Post Code</span>
                                        <span class="info-value">@a.PostCode</span>
                                    </div>
                                }
                                else
                                {
                                    <p class="text-muted small mb-0">No address on file.</p>
                                }
                            </ChildContent>
                        </Card>
                    </div>
                    <Card Title="Linked Job">
                        <ChildContent>
                            @if (_quote.JobId is { } jobId && !string.IsNullOrWhiteSpace(_quote.JobNumber))
                            {
                                <p class="mb-0">
                                    <a class="prs-link" href="@($"/jobs/{jobId}")">Job #@_quote.JobNumber</a>
                                </p>
                            }
                            else
                            {
                                <p class="text-muted small mb-0">No job linked.</p>
                            }
                        </ChildContent>
                    </Card>
                    @if (_quotePdf is not null)
                    {
                        <Card Title="PDF Preview">
                            <ChildContent>
                                <iframe title="Quote PDF preview"
                                        class="quote-pdf-preview border-rad border-grey"
                                        src="@(Helpers.GetPDFUrl(_quotePdf.Data))" />
                            </ChildContent>
                        </Card>
                    }
                </section>
                <section>
                    <Card Title="Fees">
                        <ChildContent>
                            @if (_quote.QuoteItems.Length == 0)
                            {
                                <p class="text-muted small mb-0">No line items.</p>
                            }
                            else
                            {
                                <div class="quote-detail-lines border-rad border-grey overflow-hidden">
                                    <div class="quote-detail-lines-head d-none d-md-grid">
                                        <span>Service</span>
                                        <span>Description</span>
                                        <span class="text-md-end">Amount (+GST)</span>
                                    </div>
                                    @foreach (QuoteItemDto line in _quote.QuoteItems)
                                    {
                                        <div class="quote-detail-line-row">
                                            <div>
                                                <span class="d-md-none text-muted small">Service</span>
                                                <span class="fw-semibold d-block">@line.ServiceName</span>
                                            </div>
                                            <div>
                                                <span class="d-md-none text-muted small"></span>
                                                <span class="d-block"></span>
                                            </div>
                                            <div class="text-md-end fw-semibold">@line.Price.ToString("C", QuoteCurrencyCulture)</div>
                                        </div>
                                    }
                                    <div class="quote-detail-lines-total">
                                        <span class="fw-semibold">Total (ex. GST)</span>
                                        <span class="fw-semibold">@_quote.TotalPrice.ToString("C", QuoteCurrencyCulture)</span>
                                    </div>
                                </div>
                            }
                        </ChildContent>
                    </Card>
                    <Card Title="Timeline">
                        <ChildContent>
                            <div class="info-row">
                                <span class="info-label">Target delivery</span>
                                <span class="info-value">@(_quote.TargetDeliveryDate is { } t ? t.ToLocalDateTimeString() : "—")</span>
                            </div>
                            @if (_quote.QuotesStatus.StatusEnum is QuoteStatusEnum.Rejected or QuoteStatusEnum.Accepted)
                            {
                                <div class="info-row">
                                    <span class="info-label">Client Response At</span>
                                    <span class="info-value">@(_quote.AcceptedByClientAt is { } v ? v.ToLocalDateTimeString() : "—")</span>
                                </div>
                            }
                            @if (_quote.QuotesStatus.StatusEnum is QuoteStatusEnum.Sent or QuoteStatusEnum.Accepted)
                            {
                                <div class="info-row">
                                    <span class="info-label">Viewed by client</span>
                                    <span class="info-value">@(_quote.ViewedByClientAt is { } v ? v.ToLocalDateTimeString() : "—")</span>
                                </div>
                            }
                            <div class="info-row">
                                <span class="info-label">Sent to client</span>
                                <span class="info-value">@(_quote.DateSentToClient is { } s ? s.ToLocalDateTimeString() : "—")</span>
                            </div>
                            <div class="info-row">
                                <span class="info-label">Created</span>
                                <span class="info-value">@_quote.CreatedAt.ToLocalDateTimeString() · @_quote.Createdby</span>
                            </div>
                            @if (_quote.UpdatedAt is { } updated)
                            {
                                <div class="info-row">
                                    <span class="info-label">Last updated</span>
                                    <span class="info-value">@updated.ToLocalDateTimeString() · @(_quote.UpdatedBy ?? "—")</span>
                                </div>
                            }
                        </ChildContent>
                    </Card>
                    <Card Title="History">
                        <ChildContent>
                            <div class="activity-list" style="max-height: 500px; overflow: scroll;">
                                @foreach (var history in _quote.QuoteHistory)
                                {
                                    <div class="activity-item border-grey d-flex flex-row justify-content-between">
                                        <div>
                                            <div class="activity-title">@history.DateChanged.ToLocalDateTimeString()</div>
                                            <div class="activity-time">@history.ModifiedByUserName</div>
                                        </div>
                                        <QuoteStatusBadge SingleStatus="@history.Status" />
                                    </div>
                                }
                            </div>
                        </ChildContent>
                    </Card>
                </section>
            </div>
        </div>
    }
}
