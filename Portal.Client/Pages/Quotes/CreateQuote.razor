@page "/quotes/create"
@using Portal.Data.Models
@using Portal.Shared.DTO.Quote
@using Portal.Shared.DTO.Types
@using System.Globalization
@inherits BaseDataComponent

<div class="container">
    <Card>
        <ChildContent>
            <h2>New Quote</h2>
            <div class="quote-container">
                <MudStepper @bind-ActiveIndex="_stepperIndex" Vertical Class="border-rad border-grey p-2">
                    <LabelTemplate>
                        @if (context.IsActive)
                        {
                            if (_stepperIndex is 0)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Person2" Color="Color.Secondary"></MudIcon>
                            }
                            else if (_stepperIndex is 1)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Color="Color.Secondary"></MudIcon>
                            }
                            else
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Description" Color="Color.Secondary"></MudIcon>
                            }
                        }
                        else if (context.Completed)
                        {
                            <div style="height: 10px; width:10px; background-color: var(--color-secondary); border-radius: 50%;">
                            </div>
                        }
                        else
                        {
                            <div style="height: 10px; width:10px; background-color: #d4ddeb; border-radius: 50%;"></div>
                        }
                    </LabelTemplate>
                    <ChildContent>
                        <MudStep Title="Quote Details" SecondaryText="Quoting details. Contact, Address, Type..."
                                 @ref="_mudStep">
                            <div>
                                <h5 class="form-section-title border-bottom py-2">Contact Details</h5>
                                <div class="d-flex flex-row gap-2 grey-background p-3 border-rad border-grey mb-3">
                                    <MudAutocomplete Placeholder="Select a contact" name="job-contact"
                                                     T="ListContactDto" Value="_jobContact" ValueChanged="OnContactChanged"
                                                     Clearable="false" Variant="Variant.Outlined" DebounceInterval="100"
                                                     SearchFunc="@SearchContacts" ToStringFunc="@(e=> e.ToString())" MaxItems="50"
                                                     Required="true">
                                        <MoreItemsTemplate>
                                            <div class="d-flex justify-content-center">
                                                <small>
                                                    Only the first 50 items are shown
                                                </small>
                                            </div>
                                        </MoreItemsTemplate>
                                    </MudAutocomplete>
                                    <ButtonIcon Href="contacts/create" Icon="bi bi-plus" />
                                </div>

                                <EditAddress Address="_model.Address" />
                            </div>
                        </MudStep>
                        <MudStep Title="Fees" SecondaryText="Select fees to apply for this quote." Skippable="false">
                            <h5 class="form-section-title border-bottom pb-2">Fees</h5>
                            <div>
                                <label for="template-select">Select a quote template</label>
                                <div class="quote-templates mb-3 d-flex flex-row flex-wrap gap-2">
                                    @if (_templates.Length == 0)
                                    {
                                        <p class="settings-empty">No templates available. Please create a quote template first.</p>
                                    }
                                    else
                                        @foreach (QuoteTemplateDto template in _templates)
                                        {
                                            <div class="grey-background border-grey border-rad p-3 cursor-pointer hover" @onclick="() => SelectTemplate(template)">
                                                <strong>@template.Name</strong>
                                                <small class="d-block">@template.Description</small>
                                            </div>
                                        }
                                </div>
                            </div>

                            <section class="settings-panel settings-panel-span-full">
                                <div class="settings-type-list">
                                    <div class="settings-type-row settings-type-row--head settings-type-row--service">
                                        <span>Name</span>
                                        <span>Description</span>
                                        <span>Cost</span>
                                        <span>Edit</span>
                                    </div>
                                    @if (_model.QuoteItems.Count == 0)
                                    {
                                        <p class="settings-empty">No Fees yet.</p>
                                    }
                                    else
                                    {
                                        @foreach (QuoteItemDto t in _model.QuoteItems)
                                        {
                                            <div class="settings-type-row settings-type-row--service">
                                                @if (t.IsEditing)
                                                {
                                                    <div class="settings-type-secondary">
                                                        <label>Service</label>
                                                        <MudSelect T="ServiceTypeDto" @bind-Value="_serviceType"
                                                                   Variant="Variant.Outlined" Placeholder="Service Type">
                                                            @foreach (ServiceTypeDto service in _services)
                                                            {
                                                                <MudSelectItem Value="service">
                                                                    @service.Code
                                                                    <small>
                                                                        (@service.ServiceName)
                                                                    </small>
                                                                </MudSelectItem>
                                                            }
                                                        </MudSelect>
                                                    </div>
                                                    <div class="settings-type-secondary">
                                                        <label>Description</label>
                                                        <MudTextField @bind-Value="t.Description" Variant="Variant.Outlined"
                                                                      Placeholder="Description" />
                                                    </div>
                                                    <div class="settings-type-secondary">
                                                        <label for="cost">Cost</label>
                                                        <MudNumericField name="cost" T="decimal" @bind-Value="t.Price"
                                                                         Variant="Variant.Outlined" Placeholder="Amount"
                                                                         AdornmentIcon="" />
                                                    </div>
                                                    <div class="d-flex align-items-center">
                                                        <ButtonIcon Icon="bi bi-check-lg" CssClass="text-green" Title="Save" OnClick="@(() => t.IsEditing = false)" />
                                                        <ButtonIcon Icon="bi bi-x-lg ms-2" CssClass="text-red ms-2" Title="Cancel" OnClick="@(() => t.IsEditing = false)" />
                                                    </div>
                                                }
                                                else
                                                {
                                                    <span class="settings-type-secondary">@(t.ServiceName)</span>
                                                    <span class="settings-type-secondary">@(t.Description)</span>
                                                    <span class="settings-type-primary">@t.Price.ToString("C", new CultureInfo("en-US"))</span>
                                                    <span class="settings-type-actions">
                                                        <ButtonIcon Icon="bi bi-trash" Title="Remove" CssClass="text-red" OnClick="@(() => RemoveService(t))" />
                                                        <ButtonIcon Icon="bi bi-pencil" Title="Edit" OnClick="@(() => t.IsEditing = true)" CssClass="ms-2" />
                                                    </span>
                                                }
                                            </div>
                                        }
                                    }
                                    <div class="d-flex flex-row gap-2 justify-content-between border-rad grey-background p-3">
                                        <div class="settings-type-secondary">
                                            <label>Service</label>
                                            <MudSelect T="ServiceTypeDto" @bind-Value="_serviceType"
                                                       Variant="Variant.Outlined" Placeholder="Service Type">
                                                @foreach (ServiceTypeDto service in _services)
                                                {
                                                    <MudSelectItem Value="service">
                                                        @service.Code
                                                        <small>
                                                            (@service.ServiceName)
                                                        </small>
                                                    </MudSelectItem>
                                                }
                                            </MudSelect>
                                        </div>
                                        <div>
                                            <label>Description</label>
                                            <MudTextField @bind-Value="_description" Variant="Variant.Outlined"
                                                          Placeholder="Description" />
                                        </div>
                                        <div>
                                            <label for="cost">Cost</label>
                                            <MudNumericField name="cost" T="decimal" @bind-Value="_price"
                                                             Variant="Variant.Outlined" Placeholder="Amount"
                                                             AdornmentIcon="" />
                                        </div>
                                        <div class="d-flex align-items-center">
                                            <ButtonIcon Icon="bi bi-plus" CssClass="text-green" Title="Remove" OnClick="@AddService" />
                                        </div>
                                    </div>
                                </div>
                            </section>
                        </MudStep>
                        <MudStep Title="Review">
                            <h5 class="form-section-title border-bottom pb-2">Review</h5>
                            
                        </MudStep>
                    </ChildContent>
                    <CompletedContent>
                   
                    </CompletedContent>
                </MudStepper>
                <div class="border-rad border-grey p-3 d-flex flex-column gap-2">
                    <h5 class="form-section-title border-bottom py-2">Quote Summary</h5>
                    @if (_jobContact is not null)
                    {
                        <div class="p-3 grey-background border-rad border-grey d-flex flex-column">
                            <b>Contact Details</b>
                            <div class="info-row">
                                <span class="info-label">Name</span>
                                <span class="info-value">
                                    <a class="contact-link"
                                       href="@_navigationManager.ToAbsoluteUri($"/contacts/{_jobContact.ContactId}").ToString()"
                                       target="_blank" rel="noopener noreferrer">@_jobContact.FullName</a>
                                </span>
                            </div>
                            <div class="info-row">
                                <span class="info-label">Phone</span>
                                <span class="info-value">
                                    @_jobContact.Phone
                                </span>
                            </div>
                            <div class="info-row">
                                <span class="info-label">Email</span>
                                <span class="info-value">@_jobContact.Email</span>
                            </div>
                        </div>
                    }

                    <div class="p-3 grey-background border-rad border-grey d-flex flex-column">
                        <b>Address Details</b>
                        <div class="info-row">
                            <span class="info-label">Address</span>
                            <span class="info-value">
                                @_model.Address.ToDisplayString()
                            </span>
                        </div>
                    </div>

                    <div class="p-3 grey-background border-rad border-grey d-flex flex-column">
                        <b>Fee Summary</b>
                        @if (_model.QuoteItems is not [])
                        {
                            <div class="info-row">
                                <span class="info-label">Email</span>
                                <span class="info-value">
                                </span>
                            </div>
                        }
                        else
                        {
                            <span class="info-label">No fees added yet</span>
                        }
                    </div>

                </div>
            </div>
        </ChildContent>
    </Card>
</div>