@inherits BaseDataComponent;
@using Portal.Shared
@using Portal.Shared.DataEnums
@using Portal.Shared.DTO.Contact
@using Portal.Shared.DTO.Quote
@using Portal.Shared.DTO.Types
@using Portal.Shared.Helpers
@using Portal.Shared.ResponseModels
@using Portal.Shared.Web

@page "/quotes"

<PageTitle>Quotes - PRS Portal</PageTitle>

<div class="container">
    <PageHeader>
        <Content>
            <div class="page-header">
                <div class="" style="min-width: 150px">
                    <h2>Quotes</h2>
                </div>
                <div class="search-container ml-2">
                    <MudTextField TextUpdateSuppression="false" T="string" @bind-Value="AddressSearch" Immediate="true" DebounceInterval="1000" Placeholder="Search by Address" Adornment="Adornment.Start" TextChanged="(async (x) => { AddressSearch = x; await OnSearch(); })" Variant="Variant.Outlined"
                                  AdornmentIcon="@Icons.Material.Filled.OtherHouses" IconSize="Size.Medium" Class="" Clearable="true" OnClearButtonClick="@(() => { _filterState.AddressSearch = null; _ = OnSearch(); })"></MudTextField>
                    <MudTextField TextUpdateSuppression="false" T="string" @bind-Value="JobNumberSearch" Immediate="true" DebounceInterval="1000" Placeholder="Search by Job Number" Adornment="Adornment.Start" TextChanged="(async (x) => { JobNumberSearch = x; await OnSearch(); })" Variant="Variant.Outlined"
                                  AdornmentIcon="@Icons.Material.Filled.Numbers" IconSize="Size.Medium" Class="" Clearable="true" OnClearButtonClick="@(() => { _filterState.JobNumberSearch = null; _ = OnSearch(); })"></MudTextField>
                    <MudTextField TextUpdateSuppression="false" T="string" @bind-Value="ContactSearch" Immediate="true" DebounceInterval="1000" Placeholder="Search by Contact" Adornment="Adornment.Start" TextChanged="(async (x) => { ContactSearch = x; await OnSearch(); })" Variant="Variant.Outlined"
                                  AdornmentIcon="@Icons.Material.Filled.Group" IconSize="Size.Medium" Class="" Clearable="true" OnClearButtonClick="@(() => { _filterState.ContactSearch = null; _ = OnSearch(); })"></MudTextField>
                </div>
            </div>
        </Content>
    </PageHeader>
    <Card>
        <TitleContent>
            <HeaderTabs OnTabSelect="ShowDelete" Href="/quotes/create" />
        </TitleContent>
        <ChildContent>
            <MudDataGrid T="QuoteListDto"
                         ServerData="LoadQuotes"
                         Filterable="true"
                         SortMode="SortMode.Single"
                         Loading="base.IsLoading"
                         RowsPerPage="_rowsPerPage"
                         CurrentPage="_filterState.Page"
                         CurrentPageChanged="@((page) => { _filterState.Page = page; UpdateUrlFromState(); })"
                         Dense=true
                         Hover="true"
                         @ref="_grid"
                         Striped="true">
                <Columns>
                    <TemplateColumn ShowFilterIcon="false" Title="Status" Sortable="false">
                        <CellTemplate>
                            <QuoteStatusBadge SingleStatus="context.Item.Status" />
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Property="x => x.QuoteReference" ShowFilterIcon="false" Sortable="true" Title="Quote ref" HeaderStyle="max-width: 120px">
                        <CellTemplate>
                            <a class="prs-link" href=@($"/quotes/{context.Item.Id}")>@context.Item.QuoteReference</a>
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Property="x => x.TotalPrice" ShowFilterIcon="false" Sortable="false" Title="Total">
                        <CellTemplate>
                            @(context.Item.TotalPrice is { } p ? p.ToString("C2", new System.Globalization.CultureInfo("en-US")) : "—")
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn ShowFilterIcon="false" Title="Contact">
                        <CellTemplate>
                            @if (context.Item.Contact is { } c)
                            {
                                <a class="prs-link" href="/contacts/@c.contactId">@c.fullName</a>
                            }
                        </CellTemplate>
                    </TemplateColumn>
                    <PropertyColumn Property="x => x.Address!.Street" ShowFilterIcon="false" Title="Street" />
                    <PropertyColumn Property="x => x.Address!.Suburb" ShowFilterIcon="false" Title="Suburb" />
                    <TemplateColumn ShowFilterIcon="false" Title="Job #" HeaderStyle="max-width: 90px">
                        <CellTemplate>
                            @if (context.Item.JobId is { } jobId && !string.IsNullOrWhiteSpace(context.Item.JobNumber))
                            {
                                <a class="prs-link" href=@($"/jobs/{jobId}")>@context.Item.JobNumber</a>
                            }
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn StickyRight="true" Title="Action" HeaderStyle="max-width: 130px">
                        <CellTemplate>
                            <div class="d-flex flex-row gap-1">
                                @if (context.Item.Status.StatusEnum is QuoteStatusEnum.New or QuoteStatusEnum.Draft)
                                {   
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" title="Edit" Color="Color.Primary" Href="@($"/quotes/edit/{context.Item.Id}")" Variant="Variant.Outlined" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                   Title="Delete"
                                                   Color="Color.Error"
                                                   OnClick="@(() => RemoveQuote(context.Item.Id))" Variant="Variant.Outlined" />
                                }
                            </div>
                        </CellTemplate>
                    </TemplateColumn>
                </Columns>
                <PagerContent>
                    <MudDataGridPager T="QuoteListDto" />
                </PagerContent>
            </MudDataGrid>
        </ChildContent>
    </Card>

    <Card CssClass="mt-3">
        <ChildContent>
            <h3 class="quotes-templates-heading border-bottom pb-2 mb-3">Quoting templates</h3>
            <p class="text-muted small mb-3">Templates supply default fee lines when creating a new quote.</p>

            @if (_quotingTemplates.Length > 0)
            {
                <div class="mb-4">
                    <h4 class="quotes-templates-subheading mb-2">Existing templates</h4>
                    <div class="d-flex flex-row flex-wrap gap-2">
                        @foreach (QuoteTemplateDto t in _quotingTemplates)
                        {
                            <div class="@($"grey-background border-rad border-grey p-3 d-flex flex-wrap justify-content-between align-items-start gap-2 quotes-template-existing-card {(_editingTemplateSnapshot?.Id == t.Id ? "quotes-template-existing-card--editing" : "")}")">
                                <div class="flex-grow-1 min-w-0">
                                    <strong>@t.Name</strong>
                                    @if (!string.IsNullOrWhiteSpace(t.Description))
                                    {
                                        <div class="small text-muted mt-1">@t.Description</div>
                                    }
                                    <span class="small text-muted mt-1">Fee Items:</span> @(t.QuoteTemplateItems?.Length ?? 0)
                                    <div class="small mt-1">
                                        <StatusBadge SingleStatus="@t.JobType" />
                                    </div>
                                    @if (!t.IsActive)
                                    {
                                        <span class="small text-muted d-block mt-1">Inactive</span>
                                    }
                                </div>
                                <div class="d-flex flex-row gap-1 align-items-start flex-shrink-0">
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                   Variant="Variant.Filled"
                                                   title="Edit template"
                                                   aria-label="Edit template"
                                                   Disabled="_templateFormBusy"
                                                   OnClick="@(() => BeginEditTemplate(t))" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                   Color="Color.Error"
                                                   Variant="Variant.Filled"
                                                   title="Delete template"
                                                   aria-label="Delete template"
                                                   Disabled="_templateFormBusy"
                                                   OnClick="@(() => DeleteQuotingTemplateAsync(t))" />
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

            <div class="quotes-template-create-card grey-background border-rad border-grey p-3 p-md-4">
                <div class="quotes-template-create-card-header">
                    @if (_editingTemplateSnapshot is null)
                    {
                        <h4 class="quotes-templates-subheading mb-1">Create new template</h4>
                        <p class="text-muted small mb-0">Name, type, and optional default services for new quotes.</p>
                    }
                    else
                    {
                        <h4 class="quotes-templates-subheading mb-1">Edit template</h4>
                        <p class="text-muted small mb-0">Updating <strong>@_editingTemplateSnapshot.Name</strong>. Changes apply the next time this template is used on a quote.</p>
                    }
                </div>

                @if (_serviceTypesForTemplates.Length == 0)
                {
                    <p class="text-muted small mb-0 mt-3">Service types are not available. Check Settings or try again later.</p>
                }
                else
                {
                    <div class="quotes-template-create-grid mt-3">
                        <div class="quotes-template-field quotes-template-field-name">
                            <label for="template-name" class="required-field-label">Template name</label>
                            <MudTextField name="template-name" T="string" @bind-Value="_newTemplateName" Variant="Variant.Outlined" Required="true" Class="w-100" Margin="Margin.Dense" />
                        </div>
                        <div class="quotes-template-field quotes-template-field-desc">
                            <label for="template-description" class="required-field-label">Template description</label>
                            <MudTextField name="template-description" T="string" @bind-Value="_newTemplateDescription" Variant="Variant.Outlined" Lines="4" Class="w-100 quotes-template-desc-field" Margin="Margin.Dense" />
                        </div>
                        <div class="quotes-template-field quotes-template-field-type">
                            <label for="job-type" class="required-field-label">Type</label>
                            <MudSelect name="job-type" T="JobTypeEnum" @bind-Value="_newTemplateJobType" Variant="Variant.Outlined" Class="w-100" Margin="Margin.Dense">
                                <MudSelectItem T="JobTypeEnum" Value="JobTypeEnum.Construction">@JobTypeEnum.Construction.GetDisplayName()</MudSelectItem>
                                <MudSelectItem T="JobTypeEnum" Value="JobTypeEnum.Surveying">@JobTypeEnum.Surveying.GetDisplayName()</MudSelectItem>
                            </MudSelect>
                        </div>
                    </div>

                    <div class="quotes-template-fee-lines mt-4">
                        <div class="quotes-template-fee-lines-toolbar d-flex flex-wrap align-items-start justify-content-between gap-2 mb-2">
                            <div>
                                <span class="quotes-template-fee-lines-title d-block">Default fee lines</span>
                                <span class="text-muted small">Optional — add services with default prices, or save a name-only template.</span>
                            </div>
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Success"
                                       StartIcon="@Icons.Material.Filled.Add"
                                       title="Add default fee line"
                                       Disabled="_templateFormBusy"
                                       OnClick="AddNewTemplateLine">
                                Add line
                            </MudButton>
                        </div>
                        @if (_newTemplateLines.Count == 0)
                        {
                            <div class="quotes-template-fee-lines-empty">
                                <i class="bi bi-ui-checks-grid quotes-template-fee-lines-empty-icon" aria-hidden="true"></i>
                                <p class="mb-0 small text-muted">No lines yet. Use <strong>Add line</strong> to pre-fill services when this template is used.</p>
                            </div>
                        }
                        else
                        {
                            <div class="d-flex flex-column gap-2">
                                @foreach (NewTemplateLineEditor line in _newTemplateLines)
                                {
                                    <div class="quotes-template-line-editor border-rad border-grey p-3 d-flex flex-column gap-2">
                                        <div class="d-flex flex-wrap gap-2 align-items-end">
                                            <MudSelect T="int?" @bind-Value="line.ServiceTypeId" Label="Service" Variant="Variant.Outlined" Class="flex-grow-1" Style="min-width: 200px;" Margin="Margin.Dense">
                                                @foreach (ServiceTypeDto svc in _serviceTypesForTemplates)
                                                {
                                                    <MudSelectItem T="int?" Value="svc.Id">@svc.ServiceName</MudSelectItem>
                                                }
                                            </MudSelect>
                                            <MudNumericField T="decimal" @bind-Value="line.DefaultPrice" Label="Default price" Variant="Variant.Outlined" Class="quotes-template-price-field" Margin="Margin.Dense" />
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                           Color="Color.Error"
                                                           Variant="Variant.Filled"
                                                           title="Remove line"
                                                           aria-label="Remove line"
                                                           Disabled="_templateFormBusy"
                                                           OnClick="@(() => RemoveNewTemplateLine(line))" />
                                        </div>
                                        <MudTextField T="string" @bind-Value="line.Description" Label="Line description (optional)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <div class="quotes-template-create-actions d-flex flex-wrap justify-content-end gap-2 mt-4 pt-3 border-top">
                        @if (_editingTemplateSnapshot is not null)
                        {
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Error"
                                       StartIcon="@Icons.Material.Filled.Close"
                                       title="Discard changes"
                                       Disabled="_templateFormBusy"
                                       OnClick="CancelTemplateEdit">
                                Cancel
                            </MudButton>
                        }
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Success"
                                   StartIcon="@Icons.Material.Filled.Save"
                                   title="@(_editingTemplateSnapshot is null ? "Create quoting template" : "Save template changes")"
                                   Disabled="_templateFormBusy"
                                   OnClick="SaveQuotingTemplateAsync">
                            @(_templateFormBusy ? "Saving…" : (_editingTemplateSnapshot is null ? "Create template" : "Save changes"))
                        </MudButton>
                    </div>
                }
            </div>
        </ChildContent>
    </Card>
</div>


