@page "/councils/{CouncilId:int}"
@inherits BaseDataComponent
@using Portal.Shared
@using Portal.Shared.DTO.Councils
@using Portal.Shared.DTO.Job
@using Portal.Shared.DTO.Address
@using Portal.Shared.Helpers

<PageTitle>Council @(_council?.CouncilName ?? CouncilId.ToString()) - PRS Portal</PageTitle>

@if (IsLoading)
{
    <div class="container">
        <div class="loading-spinner">Loading...</div>
    </div>
}
else if (_council is null)
{
    <div class="container">
        <div class="error-message">Council not found</div>
    </div>
}
else
{
    <div class="council-detail-container">
        <!-- Header -->
        <div class="council-header">
            <div class="header-left">
                <h1>@_council.CouncilName</h1>
                <div class="header-info">
                    <span>@_council.Address?.ToDisplayString()</span>
                </div>
            </div>
            <div class="header-right">
                <div class="header-actions">
                </div>
            </div>
        </div>

        <!-- Main Grid -->
        <div class="main-grid">
            <!-- Left Sidebar -->
            <div class="sidebar">
                <!-- Quick Stats -->
                <Card Title="Overview">
                    <ChildContent>
                        <div class="stats-mini">
                            <div class="stat-mini">
                                <div class="stat-mini-value">@(_council.JobCount)</div>
                                <div class="stat-mini-label">Jobs</div>
                            </div>
                            <div class="stat-mini">
                                <div class="stat-mini-value">@(_council.ContactCount)</div>
                                <div class="stat-mini-label">Contacts</div>
                            </div>
                        </div>
                    </ChildContent>
                </Card>

                <!-- Council Info -->
                <Card Title="Council Information">
                    <ChildContent>
                        <div class="info-list">
                            <div class="info-row">
                                <span class="info-label">Phone</span>
                                <span class="info-value">@(_council.Phone ?? "-")</span>
                            </div>
                            <div class="info-row">
                                <span class="info-label">Email</span>
                                <span class="info-value">@(_council.Email ?? "-")</span>
                            </div>
                            <div class="info-row">
                                <span class="info-label">Website</span>
                                <span class="info-value">
                                    @if (!string.IsNullOrWhiteSpace(_council.Website))
                                    {
                                        <a href="@_council.Website" target="_blank" rel="noopener noreferrer">@_council.Website</a>
                                    }
                                    else
                                    {
                                        <span>-</span>
                                    }
                                </span>
                            </div>
                            @if (_council.Address is not null)
                            {
                                <div class="info-row">
                                    <span class="info-label">Address</span>
                                    <span class="info-value">@(_council.Address.Street ?? "-")</span>
                                </div>
                                <div class="info-row">
                                    <span class="info-label">Suburb</span>
                                    <span class="info-value">@(_council.Address.Suburb ?? "-")</span>
                                </div>
                                <div class="info-row">
                                    <span class="info-label">State</span>
                                    <span class="info-value">@(_council.Address.State.ToString() ?? "-")</span>
                                </div>
                                <div class="info-row">
                                    <span class="info-label">Postcode</span>
                                    <span class="info-value">@(_council.Address.PostCode ?? "-")</span>
                                </div>
                            }
                        </div>
                    </ChildContent>
                </Card>

                <!-- Quick Actions -->
                <Card Title="Quick Actions">
                    <ChildContent>
                        <div class="quick-actions">
                            <button class="quick-action-btn">+ Add Contact</button>
                            <button class="quick-action-btn">+ Add Note</button>
                            <button class="quick-action-btn">+ Add Job</button>
                        </div>
                    </ChildContent>
                </Card>
            </div>

            <!-- Main Content -->
            <div class="content-area">
                <!-- Jobs -->
                <Card ShowHeaderWithTabs="true" OnTabSelect="ChangeTabs" HeaderTitle="Jobs" Tabs="[TabTypeEnum.All, TabTypeEnum.Deleted]" OnAddButtonClick="@(() => _navigationManager.NavigateTo("/jobs/edit/"))">
                    <ChildContent>
                        <MudDataGrid T="ListJobDto"
                                     ServerData="LoadJobs"
                                     Filterable="false"
                                     SortMode="SortMode.Single"
                                     Loading="base.IsLoading"
                                     RowsPerPage="_filterState.PageSize"
                                     CurrentPage="_filterState.Page"
                                     CurrentPageChanged="@((page) => { _filterState.Page = page;})"
                                     Dense=true
                                     @ref="_jobGrid"
                                     Striped="true">
                            <Columns>
                                <TemplateColumn ShowFilterIcon="false" Title="Job Type">
                                    <CellTemplate>
                                        <StatusBadge statusEnum="@((JobTypeEnum)context.Item.JobTypeInt)" />
                                    </CellTemplate>
                                </TemplateColumn>
                                <TemplateColumn Property="x => x.JobNumber" ShowFilterIcon="false" Title="Job #" HeaderStyle="max-width: 75px">
                                    <CellTemplate>
                                        <a class="contact-link" href=@($"/jobs/{context.Item.JobId}")>@context.Item.JobNumber</a>
                                    </CellTemplate>
                                </TemplateColumn>
                                <TemplateColumn Property="x => x.JobNumber" ShowFilterIcon="false" Title="Contact" HeaderStyle="max-width: 75px">
                                    <CellTemplate>
                                        <a class="contact-link" href=@($"/contacts/{context.Item.Contact1?.contactId}")>@context.Item.JoinedContactName</a>
                                    </CellTemplate>
                                </TemplateColumn>
                                <PropertyColumn Property="x => x.Address.Street" ShowFilterIcon="false" Title="Street" />
                                <PropertyColumn Property="x => x.Address.Suburb" ShowFilterIcon="false" Title="Suburb" />
                                <TemplateColumn StickyLeft="true" Title="Action" HeaderStyle="max-width: 130px">
                                    <CellTemplate>
                                        <div class="d-flex flex-row gap-1">
                                            <ButtonIcon Icon="bi bi-pencil" Title="Edit" Href="@($"/jobs/edit/{context.Item.JobId}")" />
                                            <ButtonIcon Icon="bi bi-trash" Title="Delete" CssClass="text-red" OnClick="@(() => RemoveJob(context.Item.JobId))" />
                                        </div>
                                    </CellTemplate>
                                </TemplateColumn>
                            </Columns>
                            <PagerContent>
                                <MudDataGridPager T="ListJobDto" />
                            </PagerContent>
                        </MudDataGrid>
                    </ChildContent>
                </Card>
            </div>

            <!-- Right Sidebar -->
            <div class="sidebar">
                <!-- Notes -->
                <Card>
                    <TitleContent>
                        <div class="card-header-with-tabs">
                            <div class="tabs">
                                <button class="tab active">All</button>
                                <button class="tab">Action</button>
                            </div>
                            <button class="btn-add">+</button>
                        </div>
                    </TitleContent>
                    <ChildContent>
                        <div class="empty-state" style="text-align: center; padding: 2rem;">
                            No records
                        </div>
                    </ChildContent>
                </Card>

                <!-- Activity -->
                <Card Title="Activity">
                    <ChildContent>
                        <div class="activity-list">
                            <div class="activity-item">
                                <div class="activity-title">Council Modified</div>
                                <div class="activity-time">Recently</div>
                            </div>
                        </div>
                    </ChildContent>
                </Card>
            </div>
        </div>
    </div>
}


