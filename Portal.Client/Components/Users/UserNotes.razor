@using Portal.Shared.DTO.Job
@inherits BaseDataComponent

<Card ShowHeaderWithTabs="true" HeaderTitle="My Assigned Notes" OnTabSelect="ChangeTabs" Tabs="Tabs" @ref="_cardRef" Shadow="false">
    <ChildContent>
        <MudTextField Placeholder="Search" @bind-Value="SearchString"
                      TextChanged="SearchNotes" DebounceInterval="250" Clearable=true
                      OnClearButtonClick="ClearSearch" Class="mb-3" Variant="Variant.Outlined" />
        @if (base.IsLoading)
        {
            <Spinner/>
        }
        else
        {
            @if (Notes.Length is 0)
            {
                <div class="empty-state">No records</div>
            }
            else
            {
                <div class="note-container">
                    @foreach (JobNoteDto note in Notes)
                    {
                        <div class="note-item @(note.ActionRequired ? "action-required" : "")">
                            <div class="note-content">
                                <div class="">@((MarkupString)GetHighlightedText(note.Content))</div>
                            </div>
                            <div class="note-actions">
                                <div class="note-buttons">
                                    @if (note.Deleted)
                                    {
                                        <MudIconButton Icon="@Icons.Material.Filled.Undo"
                                                       Color="Color.Error"
                                                       Variant="Variant.Filled"
                                                       title="Restore"
                                                       aria-label="Restore"
                                                       OnClick="@(async () => await DeleteNoteAsync(note))" />
                                    }
                                    else
                                    {
                                        <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                                       Variant="Variant.Filled"
                                                       title="View"
                                                       aria-label="View"
                                                       OnClick="@(async () => await OpenDialogAsync(note))" />
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                       Color="Color.Error"
                                                       Variant="Variant.Filled"
                                                       title="Delete"
                                                       aria-label="Delete"
                                                       OnClick="@(async () => await DeleteNoteAsync(note))" />
                                    }
                                </div>
                                <div class="note-meta">
                                    <div class="note-date">Created: @GetNoteDate(note)</div>
                                    <div class="note-author"> By: @(note.CreatedBy ?? "")</div>
                                    @if (note.AssignedUser is not null)
                                    {
                                        <div class="note-author"> Assigned to: @(note.AssignedUser?.displayName ?? "")</div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        }
    </ChildContent>
</Card>

