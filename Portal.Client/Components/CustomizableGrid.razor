@if (_gridState is not null)
{
    <div class=@(_isEditing ? "custom-grid edit" : "custom-grid")
         style="@_gridState.AsCss()"
         @ondragover:preventDefault
         @ondragover="() => { }"
         @ondrop="HandleDrop">

        @foreach (GridItem item in _gridState.Items)
        {
            if (!item.IsHidden)
            {
                <div class=@(_isEditing ? "outer-grid-item edit" : "outer-grid-item") style="@item.AsCss()">
                    <div class="grid-item @(_draggedItem == item ? "selected" : "")"
                         draggable="true"
                         @ondragstart="() => HandleDragStart(item)">
                        @if (item.Content is not null)
                        {
                            @item.Content
                        }
                        else
                        {
                            <h4>@item.ItemId</h4>
                            <small>Pos: @item.X, @item.Y</small>
                        }
                    </div>
                </div>
            }
        }
    </div>
    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                   Variant="Variant.Filled"
                   Color="Color.Default"
                   Class="mb-4 text-end"
                   title="Toggle edit columns"
                   aria-label="Toggle edit columns"
                   OnClick="@(_ => _isEditing = !_isEditing)" />
}

<style>
    .custom-grid {
        display: grid;
        background-color: var(--color-background);
        border-radius: var(--border-rad);
        overflow: hidden;
        transition: ease-in-out all 1s;
        gap: 1rem;
        justify-content:center;
        /* z-index: 100; */
    }

        .custom-grid.edit:hover {
            background-image: linear-gradient(to right, #e0e0e0 1px, transparent 1px), linear-gradient(to bottom, #e0e0e0 1px, transparent 1px);
            opacity: 0.8;
            transition: ease-in-out all 1s;
        }

    .outer-grid-item {
        position: relative;
    }

    .grid-item {
        box-shadow: 0 2px 2px rgba(0, 0, 0, 0.15); 
        background: var(--color-white);
        color: var(--color-primary);
        border-radius: var(--border-rad);
        padding: 1rem;
        transition: ease-in-out all 0.1s;
        position: relative;
        height: 100%;
        overflow: scroll;
    }

        .grid-item.selected {
            border: 2px solid var(--color-primary);
            transition: ease-in-out all 0.1s;
            opacity: 0.3;
            /* z-index: 0; */
        }

    @@media (max-width: 1200px) {
        /* 1. Force the grid into a single vertical stack */
        .custom-grid {
            display: flex !important;
            flex-direction: column !important;
            width: 100% !important;
            gap: 1.5rem !important; /* Spacing between the stacked items */
            height: auto !important; /* Let the container grow with the items */
        }
        /* 2. Reset the wrapper positioning */
        .outer-grid-item {
            width: 100% !important;
            max-width: 100% !important;
            height: auto !important;
            grid-column: auto !important;
            grid-row: auto !important;
            position: static !important; /* Removes any absolute/relative offsets from C# */
        }
        /* 3. Apply the height and scroll constraints */
        .grid-item {
            width: 100% !important;
            max-height: 500px !important; /* Your requested limit */
            overflow-y: auto !important; /* Enables vertical scroll */
            overflow-x: hidden !important; /* Prevents the 'too wide' horizontal scroll */
            box-sizing: border-box !important; /* Crucial: keeps padding inside the 100% width */
            /* Optional: aesthetic touch for mobile */
            display: block !important;
        }
    }

    .resize-item {
        cursor: nwse-resize; /* Diagonal resize cursor */
        position: absolute;
        bottom: 5px;
        right: 5px;
        width: 20px;
        height: 20px;
        background: unset;
        color: var(--color-primary);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 10px;
        border-radius: 4px;
        z-index: 10;
        font-size: 20px
    }

        .resize-item.drag-right {
            right: 10px;
        }
</style>