@using Portal.Shared.DTO.Contact
@using Portal.Shared.ResponseModels

<MudAutocomplete T="ListContactDto"
                 Value="Value"
                 ValueChanged="ValueChanged"
                 Placeholder="@Placeholder"
                 name="@Name"
                 Clearable="@Clearable"
                 Variant="Variant.Outlined"
                 DebounceInterval="@DebounceInterval"
                 SearchFunc="@SearchAsync"
                 ToStringFunc="@FormatItem"
                 MaxItems="@MaxItems"
                 Required="@Required"
                 Class="@Class"
                 Margin="@Margin"
                 Dense="@Dense">
    <MoreItemsTemplate>
        @if (ShowMoreItemsHint)
        {
            <div class="d-flex justify-content-center">
                <small>@MoreItemsText</small>
            </div>
        }
    </MoreItemsTemplate>
</MudAutocomplete>

@code {
    [Parameter] public ListContactDto? Value { get; set; }
    [Parameter] public EventCallback<ListContactDto?> ValueChanged { get; set; }

    [Parameter] public string? Placeholder { get; set; } = "Select a contact";
    [Parameter] public string? Name { get; set; }
    [Parameter] public bool Clearable { get; set; } = true;
    [Parameter] public bool Required { get; set; }
    [Parameter] public int MaxItems { get; set; } = 50;
    [Parameter] public int DebounceInterval { get; set; } = 100;
    [Parameter] public string? Class { get; set; }
    [Parameter] public Margin Margin { get; set; } = Margin.None;
    [Parameter] public bool Dense { get; set; }

    /// <summary>Page size passed to GetAllContacts (should be &gt;= MaxItems for meaningful &quot;more items&quot; behaviour).</summary>
    [Parameter] public int SearchPageSize { get; set; } = 100;

    /// <summary>Use NameEmailPhoneSearch instead of SearchFilter (e.g. technical contact dialog).</summary>
    [Parameter] public bool UseNameEmailPhoneSearch { get; set; }

    [Parameter] public Func<ListContactDto?, string?>? ToStringFunc { get; set; }

    [Parameter] public bool ShowMoreItemsHint { get; set; } = true;

    /// <summary>Overrides the default &quot;Only the first N items&quot; footer when set.</summary>
    [Parameter] public string? MoreItemsHint { get; set; }

    private string MoreItemsText => string.IsNullOrEmpty(MoreItemsHint)
        ? $"Only the first {MaxItems} items are shown"
        : MoreItemsHint!;

    private string FormatItem(ListContactDto? e) =>
        ToStringFunc is not null ? (ToStringFunc(e) ?? "") : (e?.ToString() ?? "");

    private async Task<IEnumerable<ListContactDto>> SearchAsync(string search, CancellationToken token)
    {
        ContactFilterDto filter = UseNameEmailPhoneSearch
            ? new ContactFilterDto(Page: 1, PageSize: SearchPageSize, NameEmailPhoneSearch: search)
            : new ContactFilterDto(
                Page: 1,
                PageSize: SearchPageSize,
                SearchFilter: search,
                OrderBy: nameof(ListContactDto.FullName),
                Order: Portal.Shared.SortDirectionEnum.Desc);

        Result<PagedResponse<ListContactDto>>? contactResult = await _apiService.GetAllContacts(filter);

        if (contactResult?.IsSuccess == true && contactResult.Value?.Result is not null)
            return contactResult.Value.Result;
        return [];
    }
}
