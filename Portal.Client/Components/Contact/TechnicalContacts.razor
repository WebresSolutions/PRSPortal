@using Portal.Client.Components.JobComponents
@using Portal.Shared
@using Portal.Shared.DTO.Contact
@inherits BaseDataComponent

<Card @ref="_cardRef" ShowHeaderWithTabs="true" HeaderTitle="Technical Contacts" OnTabSelect="ChangeTabs" Tabs="[TabTypeEnum.All, TabTypeEnum.Deleted]" TabButtonClick="@(() => NewTechnicalContact(null))">
    <ChildContent>
        <MudDataGrid T="TechnicalContactDto"
                     Items="@_technicalContactDtos"
                     Dense="true"
                     Striped="true"
                     Loading="@base.IsLoading"
                     Hover="true"
                     Breakpoint="Breakpoint.Sm"
                     FixedHeader="true"
                     SortMode="SortMode.None"
                     RowsPerPage="10"
                     @ref=@_grid>
            <Columns>
                <PropertyColumn Property="x => x.ContactType" Title="Role" />
                <TemplateColumn Title="@(JobId is not null ? "Contact" : "Job #")">
                    <CellTemplate>
                        @{
                            var contact = context.Item;
                        }
                        @if (JobId is not null)
                        {
                            <a class="prs-link" href="/contacts/@contact.ContactId">@contact.ContactName</a>
                        }
                        else
                        {
                            <a class="prs-link" href="/jobs/@contact.JobId">@contact.JobNumber</a>
                        }
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="x => x.Phone" Title="Phone" />
                <PropertyColumn Property="x => x.Email" Title="Email" />
                <TemplateColumn Title="Actions" HeaderStyle="width: 130px;">
                    <CellTemplate>
                        <div class="d-flex flex-row gap-1">
                            @if (context.Item.Deleted)
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.Undo"
                                               Color="Color.Error"
                                               Variant="Variant.Filled"
                                               title="Restore"
                                               aria-label="Restore"
                                               OnClick="@(async () => await DeletedContact(context.Item))" />
                            }
                            else if (JobId is not null)
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                               Variant="Variant.Filled"
                                               title="Edit"
                                               aria-label="Edit"
                                               OnClick="@(() => NewTechnicalContact(context.Item))" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                               Color="Color.Error"
                                               Variant="Variant.Filled"
                                               title="Delete"
                                               aria-label="Delete"
                                               OnClick="@(() => DeletedContact(context.Item))" />
                            }
                        </div>
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
            <NoRecordsContent>
                <span class="empty-state">No Records</span>
            </NoRecordsContent>
            <PagerContent>
                <MudDataGridPager T="TechnicalContactDto" />
            </PagerContent>
        </MudDataGrid>
    </ChildContent>
</Card>