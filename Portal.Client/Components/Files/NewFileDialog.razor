@using Portal.Shared.DTO.File
@using Portal.Shared.DTO.Job
@using Portal.Shared.DTO.Types
@inherits BaseDataComponent
@inject IApiService ApiService
@inject ISnackbar Snackbar

<MudDialog Style="min-width: 400px">
    <DialogContent>
        <h4 class="header-border">New File</h4>
        @if (!base.IsLoading)
        {
            <EditForm Model="@_file" OnValidSubmit="SaveFile">
                <DataAnnotationsValidator />
                <div class="new-file-container border-rad grey-background">
                    <div>
                        <label>Title</label>
                        <MudTextField T="string" Variant="Variant.Outlined" Required="true" @bind-Value="_file.Title" MaxLength="50"/>
                        <ValidationMessage For="@(() => _file.Title)" />
                    </div>
                    <p class="mb-2">Select a file to upload to this job</p>
                    <div class="file-upload-zone">
                        <InputFile OnChange="OnFileSelected"
                                   accept="image/*,.pdf"
                                   class="file-upload-input" />
                        <span class="file-upload-label">@(_selectedFile != null ? _selectedFile.Name : "Click or drop file here")</span>
                    </div>
                    <div>
                        <label for="file-type">File Category</label>
                        <MudSelect name="file-type" T="int" @bind-Value="_file.FileTypeId" Variant="Variant.Outlined">
                            @foreach (FileTypeDto fType in _fileTypes)
                            {
                                <MudSelectItem Value="@fType.Id">@fType.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </div>
                    <div>
                        <label>Description</label>
                        <MudTextField T="string" Variant="Variant.Outlined" Lines="2" @bind-Value="_file.Description" MaxLength="400"/>
                    </div>
                </div>
                <div class="d-flex justify-content-center gap-1 mt-2">
                    <ButtonIcon Icon="bi bi-save-fill"
                                CssClass="text-green"
                                Text="Save"
                                ButtonType="submit"
                                Disabled="@_saving" />
                    <ButtonIcon Icon="bi bi-x-circle"
                                CssClass="text-red"
                                Disabled="@_saving"
                                OnClick="@(() => base.MudDialog?.Close(DialogResult.Cancel()))"
                                Text="Close" />
                </div>
            </EditForm>
        }
        else
        {
            <div style="min-height: 400px">
                <Spinner />
            </div>
        }
    </DialogContent>
</MudDialog>

<style>
    .new-file-container {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        height: fit-content;
        min-width: 350px;
        overflow-y: auto;
        padding: var(--padding);
        max-height: 600px;
    }

    .file-upload-zone {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 120px;
        padding: 1rem;
        border: 2px dashed #ccc;
        border-radius: var(--border-rad);
        background: #f5f5f5;
        cursor: pointer;
    }

        .file-upload-zone:hover {
            border-color: var(--color-secondary);
            background: #eee;
        }

    .file-upload-input {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        opacity: 0;
        cursor: pointer;
    }

    .file-upload-label {
        pointer-events: none;
        color: #666;
        font-size: 0.9rem;
    }
</style>

@code {
    [Parameter]
    public int? JobId { get; set; }

    private FileDto _file = new() { FileName = "", Title = ""};
    private FileTypeDto[] _fileTypes = [];
    private IBrowserFile? _selectedFile;
    private bool _saving;

    protected override async Task OnParametersSetAsync()
    {
        base.IsLoading = true;

        Result<FileTypeDto[]> filesResult = await _apiService.GetFileTypes();
        if (filesResult.IsSuccess)
            _fileTypes = filesResult.Value!;
        else
            _snackbar.Add("Could not load file types", Severity.Error);

        if (_fileTypes is not [])
            _file.FileTypeId = _fileTypes.FirstOrDefault()!.Id;

        base.IsLoading = false;
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        _selectedFile = e.FileCount > 0 ? e.File : null;
        if (_selectedFile is null)
            return;

        IBrowserFile browserFile = _selectedFile;
        await using Stream stream = browserFile.OpenReadStream(maxAllowedSize: 20 * 1024 * 1024); // 20 MB
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        _file.FileName = browserFile.Name;
        _file.ContentType = browserFile.ContentType;
        _file.Content = ms.ToArray(); ;
        StateHasChanged();
    }

    private async Task SaveFile()
    {
        if (JobId <= 0)
        {
            Snackbar.Add("Job is not set. Cannot save file.", Severity.Error);
            return;
        }

        if (_file.Content is null or [])
        {
            Snackbar.Add("Please select a file to upload.", Severity.Warning);
            return;
        }

        _saving = true;
        try
        {
            if (JobId is null)
            {
                // If there are potentially other files that can be saved rather than just to a job
            }
            else
            {
                _file.JobId = JobId.Value;

                Result<int> result = await ApiService.SaveJobFile(JobId.Value, _file);
                if (result.IsSuccess)
                {
                    Snackbar.Add("File saved successfully.", Severity.Success);
                    base.MudDialog?.Close(DialogResult.Ok(true));
                }
                else
                {
                    Snackbar.Add(result.ErrorDescription ?? "Failed to save file.", Severity.Error);
                }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }
}
