@using GoogleMapsComponents
@using GoogleMapsComponents.Maps
@using Portal.Client.Components.Contact
@using Portal.Client.Components.JobComponents
@using Portal.Client.Components.TimeSheet
@using Portal.Client.Webmodels
@using Portal.Shared
@using Portal.Shared.DTO.Contact
@using Portal.Shared.DTO.File
@using Portal.Shared.DTO.Job
@using Portal.Shared.DTO.Address
@using Portal.Shared.Helpers

<Card ShowHeaderWithAddButton="true" HeaderTitle="@($"Job Files ({Files.Count()})")" OnAddButtonClick="CreateNewFile">
    <ChildContent>
        <div class="job-file-container">
            @foreach (FileDto file in Files)
            {
                <div class="job-file">
                    <div>
                        <strong>@file.Title</strong>
                        <small>@file.FileName.Trim()..</small>
                    </div>
                    <div class="d-flex flex-column gap-1">
                        <ButtonIcon Onclick="@(async () => await EditFile(file))" Icon="bi bi-eye-fill" />
                        <ButtonIcon OnClick="@(() => DownloadFile(file.FileId))" Icon="bi bi-cloud-arrow-down-fill" Disabled="_disabled" />
                    </div>
                </div>
            }
        </div>
        @if (Files.Count() == 0)
        {
            <div class="empty-state">No Files</div>
        }
    </ChildContent>
</Card>



<style>
    .job-file-container {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 0.5rem;
        grid-auto-rows: 1fr;
    }

    .job-file {
        background-color: white;
        width: 100%;
        height: 100px;
        border-radius: var(--border-rad);
        padding: 10px;
        transition: ease-in-out 0.2s;
        display: flex;
        flex-direction: row;
        justify-content: space-between;
        width: 100%;
        gap: 5px;
        border: 2px solid var(--color-grey);
        overflow-wrap: break-word;
        word-break: break-word;
    }

    .empty-state {
        text-align: center;
        color: #94a3b8;
        padding: 0rem 2rem;
        font-size: 0.85rem;
        width: 100%;
    }

</style>