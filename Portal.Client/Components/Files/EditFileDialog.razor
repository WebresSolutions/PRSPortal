@using Portal.Shared.DTO.File
@using Portal.Shared.DTO.Job
@inherits BaseDataComponent
@inject IApiService ApiService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <h4 class="header-border">Edit File</h4>
        @if (!base.IsLoading)
        {
            <EditForm Model="@File" class="edit-file-container border-rad grey-background">
                <DataAnnotationsValidator />
                <div>
                    <label for="title">Title</label>
                    <MudTextField T="string" Value="File.Title" Variant="Variant.Outlined" Required="true" />
                </div>
                <div>
                    <p class="mb-2">Select a new file to replace the current one</p>
                    <div class="file-upload-zone">
                        <InputFile OnChange="OnFileSelected"
                                   accept="*"
                                   class="file-upload-input" />
                        <span class="file-upload-label">@(_selectedFile != null ? _selectedFile.Name : "Click or drop file here")</span>
                    </div>
                    <p class="mt-2 current-file"><strong>Current file:</strong> @File.FileName</p>
                </div>
                <div>
                    <label for="file-type">File Type</label>
                    <MudSelect name="file-type" T="int" @bind-Value="File.FileTypeId" Variant="Variant.Outlined">
                        @foreach (FileTypeDto fType in _fileTypes)
                        {
                            <MudSelectItem Value="fType.Id">@fType.Name</MudSelectItem>
                        }
                    </MudSelect>
                </div>
                <div>
                    <label>Description</label>
                    <MudTextField T="string" Value="File.Description" Variant="Variant.Outlined" Lines="2" />
                </div>
                <small>Uploaded On: @File.DateCreated.ToLocalTime().ToString("g")</small>
                <small>Created By: @File.CreatedBy</small>
            </EditForm>
            <div class="d-flex justify-content-center gap-1 mt-2">
                <ButtonIcon Icon="bi bi-save-fill"
                            CssClass="text-green"
                            Text="Save"
                            Disabled="@_saving"
                            OnClick="SaveFile" />
                <ButtonIcon Icon="bi bi-x-circle"
                            CssClass="text-red"
                            Disabled="@_saving"
                            OnClick="@(() => base.MudDialog?.Close(DialogResult.Cancel()))"
                            Text="Close" />
            </div>
        }
        else
        {
            <div style="min-height: 400px">
                <Spinner />
            </div>
        }
    </DialogContent>
</MudDialog>

<style>
    .edit-file-container {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        height: fit-content;
        min-width: 350px;
        overflow-y: auto;
        padding: var(--padding);
        max-height: 600px;
    }

    .file-upload-zone {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 120px;
        padding: 1rem;
        border: 2px dashed #ccc;
        border-radius: var(--border-rad);
        background: #f5f5f5;
        cursor: pointer;
    }

        .file-upload-zone:hover {
            border-color: var(--color-secondary);
            background: #eee;
        }

    .file-upload-input {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        opacity: 0;
        cursor: pointer;
    }

    .file-upload-label {
        pointer-events: none;
        color: #666;
        font-size: 0.9rem;
    }

</style>

@code {
    [Parameter]
    public required FileDto File { get; set; }

    private IBrowserFile? _selectedFile;
    private bool _saving;
    private FileTypeDto[] _fileTypes = [];

    protected override async Task OnParametersSetAsync()
    {
        base.IsLoading = true;
        Result<FileTypeDto[]> filesResult = await _apiService.GetFileTypes();
        if (filesResult.IsSuccess)
            _fileTypes = filesResult.Value!;
        else
            _snackbar.Add("Could not load file types", Severity.Error);

        if (_fileTypes is not [])
            File.FileTypeId = _fileTypes.FirstOrDefault()!.Id;

        base.IsLoading = false;
    }

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        _selectedFile = e.FileCount > 0 ? e.File : null;
        StateHasChanged();
    }

    private async Task SaveFile()
    {
        if (File.JobId <= 0)
        {
            Snackbar.Add("Job is not set. Cannot save file.", Severity.Error);
            return;
        }

        IBrowserFile? browserFile = _selectedFile;
        if (browserFile is null)
        {
            Snackbar.Add("Please select a file to upload or replace.", Severity.Warning);
            return;
        }

        _saving = true;
        try
        {
            await using Stream stream = browserFile.OpenReadStream(maxAllowedSize: 20 * 1024 * 1024); // 20 MB
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            byte[] content = ms.ToArray();

            FileDto dto = new()
            {
                JobId = File.JobId,
                FileId = File.FileId,
                FileName = browserFile.Name,
                ContentType = browserFile.ContentType,
                Content = content,
                FileTypeId = File.FileTypeId,
                DateCreated = File.DateCreated,
                DateModified = DateTime.UtcNow,
            };

            Result<int> result = await ApiService.SaveJobFile(File.JobId, dto);
            if (result.IsSuccess)
            {
                Snackbar.Add("File saved successfully.", Severity.Success);
                base.MudDialog?.Close(DialogResult.Ok(true));
            }
            else
            {
                Snackbar.Add(result.ErrorDescription ?? "Failed to save file.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }
}
