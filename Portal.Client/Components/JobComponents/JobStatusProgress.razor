@using Portal.Shared.DTO.Job
@using Portal.Shared.DTO.Types

@if (OrderedStatuses.Count > 0)
{
    <div class="job-status-progress" role="list" aria-label="Job status pipeline">
        <div class="job-status-track">
            @for (var i = 0; i < OrderedStatuses.Count; i++)
            {
                int idx = i;
                JobTypeStatusDto step = OrderedStatuses[idx];
                <div class="job-status-step-cell" role="listitem">
                    <div class="job-status-step job-status-step--@ProgressState(idx)"
                         style="@($"--step-accent: {step.Colour}; z-index: {idx + 1};")"
                         title="@step.Name">
                        <span class="job-status-step-index job-status-step-title" aria-hidden="true">@step.Name</span>
                    </div>
                </div>
            }
        </div>
    </div>
}
