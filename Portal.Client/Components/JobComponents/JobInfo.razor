@using Portal.Shared.DTO.User
@using Portal.Shared.DataEnums

<Card Title="Job Information">
    <ChildContent>
        <div class="info-list">
            @if (Job.PrimaryContact is not null)
            {
                <div class="info-row">
                    <span class="info-label">Contact</span>
                    <span class="info-value">
                        <a style="color: var(--color-secondary)" href=@($"/contacts/{Job.PrimaryContact!.ContactId}")>@Job.PrimaryContact.ContactName</a>
                    </span>
                </div>
                <div class="info-row">
                    <span class="info-label">Email</span>
                    <span class="info-value">@Job.PrimaryContact.Email</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Phone</span>
                    <span class="info-value">@Job.PrimaryContact.Phone</span>
                </div>
            }
            @if (_currentOwner is not null)
            {
                <div class="info-row">
                    <span class="info-label">Current Owner</span>
                    <span class="info-value">
                        <a style="color: var(--color-secondary)" href=@($"/contacts/{Job.PrimaryContact!.ContactId}")>@_currentOwner.Name</a>
                    </span>
                </div>
            }
            @if (_responsibleUser is not null)
            {
                <div class="info-row">
                    <span class="info-label">Responsible Team Member</span>
                    <span class="info-value">
                        <a style="color: var(--color-secondary)")>@_responsibleUser.Name</a>
                    </span>
                </div>
            }

            @if (Job.Council is not null)
            {
                <div class="info-row">
                    <span class="info-label">Council</span>

                    <span class="info-value">
                        <a style="color: var(--color-secondary)" href=@($"/councils/{Job.Council!.CouncilId}")>@Job.Council.CouncilName</a>
                    </span>
                </div>
            }
            @if (!string.IsNullOrEmpty(""))
            {
                <div class="info-row">
                    <span class="info-label">Plan Ref</span>
                    <span class="info-value"></span>
                </div>
            }
            @if (!string.IsNullOrEmpty(Job.Details))
            {
                <div class="info-row">
                    <span class="info-label">@Job.Details</span>
                </div>
            }
            <div class="info-row">
                <span class="info-label">Created</span>
                <span class="info-value">@(Job.DateCreated.ToLocalDateTimeString())</span>
            </div>
            <div class="info-row">
                <span class="info-label">Created By</span>
                <span class="info-value">@Job.CreatedBy</span>
            </div>
        </div>
    </ChildContent>
</Card>

@code {
    /// <summary>
    /// Gets or sets the contact information for the job
    /// </summary>
    [Parameter]
    public required JobDetailsDto Job { get; set; }

    private UserAssignmentDto? _currentOwner;
    private UserAssignmentDto? _responsibleUser;

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        _currentOwner = Job.AssignedUsers.FirstOrDefault(x => x.assignmentType is JobAssignementTypeEnum.CurrentOwner);
        _responsibleUser = Job.AssignedUsers.FirstOrDefault(x => x.assignmentType is JobAssignementTypeEnum.Responsible);
    }

}

