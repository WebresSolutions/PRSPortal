@using Portal.Shared.DTO.Job
@using System.Globalization

<Card Title="Job Information">
    <ChildContent>
        <div class="info-list">
            @if (Job.PrimaryContact is not null)
            {
                <div class="info-row">
                    <span class="info-label">Contact</span>
                    <span class="info-value">
                        <a style="color: var(--color-secondary)" href=@($"/contacts/{Job.PrimaryContact!.ContactId}")>@Job.PrimaryContact.ContactName</a>
                    </span>
                </div>
                <div class="info-row">
                    <span class="info-label">Email</span>
                    <span class="info-value">@Job.PrimaryContact.Email</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Phone</span>
                    <span class="info-value">@Job.PrimaryContact.Phone</span>
                </div>
            }
            @if (Job.Council is not null)
            {
                <div class="info-row">
                    <span class="info-label">Council</span>

                    <span class="info-value">
                        <a style="color: var(--color-secondary)" href=@($"/councils/{Job.Council!.CouncilId}")>@Job.Council.CouncilName</a>
                    </span>
                </div>
            }
            @if (!string.IsNullOrEmpty(""))
            {
                <div class="info-row">
                    <span class="info-label">Plan Ref</span>
                    <span class="info-value"></span>
                </div>
            }
            @if (!string.IsNullOrEmpty(Job.Details))
            {
                <div class="info-row">
                    <span class="info-label">@Job.Details</span>
                </div>
            }
            <div class="info-row">
                <span class="info-label">Created</span>
                <span class="info-value">@Job.DateCreated.ToLocalTime().ToString("g", CultureInfo.CreateSpecificCulture("en-AU"))</span>
            </div>
            <div class="info-row">
                <span class="info-label">Created By</span>
                <span class="info-value">@Job.CreatedBy</span>
            </div>
        </div>
    </ChildContent>
</Card>

@code {
    /// <summary>
    /// Gets or sets the contact information for the job
    /// </summary>
    [Parameter]
    public required JobDetailsDto Job { get; set; }

}

