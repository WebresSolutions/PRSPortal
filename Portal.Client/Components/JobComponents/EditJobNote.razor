@using Portal.Shared.DTO.Job
@using Portal.Shared.DTO.User
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <h4 class="header-border">Job Note</h4>
        <div class="edit-note-container border-rad">
            <div class="assign-user-container">
                <MudSelect T="int?" Label="Assign a user" Clearable="true" Variant="Variant.Outlined" MultiSelection="false" @bind-Value="_assignedUser">
                    @foreach (UserDto user in Users)
                    {
                        <MudSelectItem T="int?" Value="@user.userId">@user.displayName</MudSelectItem>
                    }
                </MudSelect>
                <MudCheckBox Label="Action Required" @bind-value="Note.ActionRequired" />
            </div>

            <MudExRichTextEdit @ref="_editor"
                               ReadOnly="_readonly"
                               Height="500"
                               Class="m-2 border-rad"
                               Value="@_saveContent"
                               ValueChanged="OnContentChanged"
                               Placeholder="Start typing...">
            </MudExRichTextEdit>

            @if (Note.DateModified is not null && Note.Modifiedby is not null)
            {
                <small class="text-center">Last Modified: @Note.DateModified.Value.ToLocalTime().ToString("dddd d-MMM-yyyy h:mmtt")</small>
                <small class="text-center">Modified By: @Note.Modifiedby</small>
            }
            <div class="action-buttons">
                <ButtonIcon Icon="bi bi-save-fill" CssClass="text-green" OnClick="SaveNote" Text="Save" />
                <ButtonIcon Icon="bi bi-x-circle" CssClass="text-red" OnClick="@(() => MudDialog?.Close(DialogResult.Ok(true)))" Text="Close" />
            </div>
        </div>
    </DialogContent>
</MudDialog>

<style>
    .edit-note-container {
        display: flex;
        flex-direction: column;
        gap: 10px;
        margin: 20px;
        padding: var(--padding);
        background: var(--color-light-grey);
    }

    .assign-user-container {
        display: flex;
        align-items: center;
        gap: 20px;
        margin: var(--padding);
    }

    .action-buttons {
        display: flex;
        gap: 10px;
        justify-content: center;
    }
</style>