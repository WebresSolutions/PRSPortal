@using Portal.Shared
<section class=@($"card-container {CssClass}" + (Shadow ? " shadow" : ""))>
    @if (TitleContent is not null)
    {
        @TitleContent
    }
    @if (ShowHeaderWithAddButton)
    {
        <div class="card-header-simple">
            <h3>@HeaderTitle</h3>
            <ButtonIcon Icon=@ButtonIcon CssClass="text-green" Title="Edit" OnClick="OnAddButtonClick" />
        </div>
    }
    @if (ShowHeaderWithTabs)
    {
        <div class="card-header-tabs">
            <h3>@HeaderTitle</h3>
            <HeaderTabs Href="#" OnTabSelect="OnTabSelect" ShowAddButton="false" ShowBorderBottom="false" Tabs="Tabs" @ref="HeaderTabsRef" />
            @if (IsEventSet)
            {
                <ButtonIcon Icon="@ButtonIcon" CssClass="text-green" Title="Edit" OnClick="TabButtonClick" />
            }
        </div>
    }
    @if (Title != string.Empty && !ShowHeaderWithAddButton)
    {
        <h1 class="cd-title">@Title</h1>
    }
    @if (IsLoading)
    {
    }
    else
    {
        <div class="">
            @ChildContent
        </div>
    }
    @if (Reload is not null)
    {
    }
</section>
@code {
    #region Parameters
    /// <summary>
    /// Gets or sets the child content to be displayed within the card
    /// </summary>
    [Parameter]
    public required RenderFragment ChildContent { get; set; }
    /// <summary>
    /// Gets or sets a value indicating whether the card is in a loading state
    /// When true, displays a skeleton loader instead of content
    /// </summary>
    [Parameter]
    public bool IsLoading { get; set; } = false;
    /// <summary>
    /// Gets or sets the title displayed at the top of the card
    /// If empty, no title is shown
    /// </summary>
    [Parameter]
    public string Title { get; set; } = string.Empty;

    /// <summary>
    /// The height of the card in pixels. Default is 300.
    /// </summary>
    [Parameter]
    public int Height { get; set; } = 300;

    /// <summary>
    /// The title actions to be displayed alongside the title.
    /// </summary>
    [Parameter]
    public Action? TitleActions { get; set; }

    /// <summary>
    /// Gets the height string for CSS styling
    /// </summary>
    private string _heightString => Height > 0 ? $"{Height}px" : "300px";

    /// <summary>
    /// Gets or sets the title content to be displayed within the card
    /// </summary>
    [Parameter]
    public RenderFragment? TitleContent { get; set; }

    /// <summary>
    /// Optionally pass a function to reload the card content
    /// </summary>
    [Parameter]
    public Func<Task>? Reload { get; set; }

    /// <summary>
    /// Gets or sets whether to show a header with an add button
    /// </summary>
    [Parameter]
    public bool ShowHeaderWithAddButton { get; set; } = false;

    /// <summary>
    /// Gets or sets the title for the header with add button
    /// </summary>
    [Parameter]
    public string HeaderTitle { get; set; } = string.Empty;

    /// <summary>
    /// Event callback for when the add button is clicked
    /// </summary>
    [Parameter]
    public EventCallback OnAddButtonClick { get; set; }

    [Parameter]
    public string? CssClass { get; set; }

    [Parameter]
    public bool ShowHeaderWithTabs { get; set; } = false;

    /// <summary>
    /// Called when a tab is selected in the header tabs. Only has effect when <see cref="ShowHeaderWithTabs"/> is true.
    /// </summary>
    [Parameter]
    public EventCallback<TabTypeEnum> OnTabSelect { get; set; }

    /// <summary>
    /// List of tabs to show in the header. Only has effect when <see cref="ShowHeaderWithTabs"/> is true. If empty, no tabs will be shown.
    /// </summary>
    [Parameter]
    public HashSet<TabTypeEnum> Tabs { get; set; } = [];

    /// <summary>
    /// Called when the add button in the header with tabs is clicked. Only has effect when <see cref="ShowHeaderWithTabs"/> is true and the event has a delegate assigned.
    /// </summary>
    [Parameter]
    public EventCallback TabButtonClick { get; set; }

    /// <summary>
    /// Changes the selected tab programmatically. Only has effect when <see cref="ShowHeaderWithTabs"/> is true and the tab is in <see cref="Tabs"/>.
    /// </summary>
    [Parameter]
    public EventCallback<TabTypeEnum> ChangeTabs { get; set; }

    [Parameter]
    public string ButtonIcon { get; set; } = "bi bi-plus";

    [Parameter]
    public bool Shadow { get; set; } = true;

    #endregion

    private bool IsEventSet => TabButtonClick.HasDelegate;
    private HeaderTabs? HeaderTabsRef;

    /// <summary>
    /// Sets the selected header tab programmatically. Only has effect when <see cref="ShowHeaderWithTabs"/> is true and the tab is in <see cref="Tabs"/>.
    /// </summary>
    /// <param name="tab">The tab to select.</param>
    public void SetSelectedTab(TabTypeEnum tab)
    {
        if (HeaderTabsRef is not null)
            HeaderTabsRef.SetTab(tab);
    }
}

<style>

    .card-container {
        background: var(--color-white);
        padding: 15px;
        border-radius: var(--border-rad);
        overflow-x: scroll !important;
        margin-right: auto;
        margin-left: auto;
        overflow: scroll;
    }

    .cd-title {
        text-align: left;
        margin-bottom: 1.5rem;
        margin-left: 1.5rem;
    }

    .card-header-simple {
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 100%;
        margin-bottom: 1rem;
        padding-bottom: 0.75rem;
        border-bottom: 1px solid #e2e8f0;
    }

        .card-header-simple h3 {
            margin: 0;
            font-size: 1rem;
            font-weight: 700;
            color: var(--color-primary);
        }

    .card-header-tabs {
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 100%;
        margin-bottom: 1rem;
        padding-bottom: 0.75rem;
        border-bottom: 1px solid #e2e8f0;
        gap: 1rem;
    }

        .card-header-tabs h3 {
            margin: 0;
            font-size: 1rem;
            font-weight: 700;
            color: var(--color-primary);
        }

    .btn-add {
        background: #10b981;
        color: white;
        border: none;
        padding: 0.4rem 0.8rem;
        border-radius: 6px;
        font-size: 0.85rem;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s;
    }

        .btn-add:hover {
            background: #059669;
        }

    .refresh-button {
        position: absolute !important;
        bottom: 0px !important;
        right: 0 !important;
    }

    .card-container {
        -ms-overflow-style: none; /* Internet Explorer 10+ */
        scrollbar-width: none !important;
    }
</style>