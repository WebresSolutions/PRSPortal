@namespace Portal.Client.Components.UIComponents

@if (Href is { Length: > 0 })
{
    <a class="@CssClassString @(Text is not null ? " custom-button " : "")" href="@Href" title="@Title" target="@(OpenInNewTab ? "_blank" : null)" rel="@(OpenInNewTab ? "noopener noreferrer" : null)">
        @if (ChildContent is not null)
        {
            @ChildContent
        }
        else
        {
            <i class="@IconClass"></i>
            @if (Text is not null)
            {
                <span class="ms-2">
                    @Text
                </span>
            }
        }
    </a>
}
else
{
    <button type="@ButtonType" class="@CssClassString @(Text is not null ? " custom-button " : "")" title="@Title" @onclick="OnClickHandler" disabled="@Disabled">
        @if (ChildContent is not null)
        {
            @ChildContent
        }
        else
        {
            <i class="@IconClass"></i>
            @if (Text is not null)
            {
                <span class="ms-2">
                    @Text
                </span>
            }
        }
    </button>
}

<style>
    .custom-button {
        display: flex;
        flex-direction: row;
        width: fit-content;
        padding: 7px
    }
</style>

@code {
    /// <summary>
    /// Bootstrap Icons class (e.g. "bi bi-trash", "bi bi-pencil").
    /// Ignored when ChildContent is provided.
    /// </summary>
    [Parameter]
    public string Icon { get; set; } = "bi bi-circle";

    /// <summary>
    /// Tooltip/title text.
    /// </summary>
    [Parameter]
    public string? Title { get; set; }

    /// <summary>
    /// Click handler. Not used when Href is set.
    /// </summary>
    [Parameter]
    public EventCallback<MouseEventArgs> OnClick { get; set; }

    /// <summary>
    /// When set, renders as a link instead of a button.
    /// </summary>
    [Parameter]
    public string? Href { get; set; }

    /// <summary>
    /// Open link in new tab when Href is set.
    /// </summary>
    [Parameter]
    public bool OpenInNewTab { get; set; }

    /// <summary>
    /// Extra CSS classes (e.g. "text-red", "pulse", "text-danger").
    /// </summary>
    [Parameter]
    public string? CssClass { get; set; }

    /// <summary>
    /// Use smaller size (btn-icon-small).
    /// </summary>
    [Parameter]
    public bool Small { get; set; }

    /// <summary>
    /// Disable the button.
    /// </summary>
    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public string? Text { get; set; }

    [Parameter]
    public string ButtonType { get; set; } = "button";

    /// <summary>
    /// Custom content instead of Icon (e.g. emoji or custom markup).
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    private string IconClass => Icon?.StartsWith("bi ") == true ? Icon : $"bi {Icon}".Trim();
    private string CssClassString => string.Join(" ", "custom-btn-icon", Small ? "custom-btn-icon-small" : "", CssClass ?? "").Trim();

    private async Task OnClickHandler(MouseEventArgs args) => await OnClick.InvokeAsync(args);
}

<style>
    .custom-btn-icon {
        min-width: 36px;
        width: fit-content !important;
        height: 36px;
        border: none;
        background: #f1f5f9;
        border-radius: 8px;
        cursor: pointer;
        font-size: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.2s;
        border: 1px solid #e2e8f0 !important;
    }

        .custom-btn-icon:hover {
            background: #e2e8f0;
        }

    .custom-btn-icon-small {
        width: 28px;
        height: 28px;
        border: none;
        background: #f1f5f9;
        border-radius: 6px;
        cursor: pointer;
        font-size: 0.85rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-right: 0.25rem;
        transition: background 0.2s;
        border: 1px solid #e2e8f0 !important;
    }

        .custom-btn-icon-small:hover {
            background: #e2e8f0;
        }
</style>