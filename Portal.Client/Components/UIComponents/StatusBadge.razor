@using Portal.Client.Components.UIComponents
@using Portal.Shared

@if (Onclick.HasDelegate)
{
    <div class="status-badge" style=@($"background-color: {color}") @onclick=@(() => Onclick.InvokeAsync())>
        @statusEnum.GetDisplayName()
    </div>
}
else
{
    <div class="status-badge" style=@($"background-color: {color}")>
        @statusEnum.GetDisplayName()
    </div>
}

@code {
    /// <summary>
    /// Gets or sets the assessment status enum to display
    /// </summary>
    [Parameter]
    public JobTypeEnum statusEnum { get; set; }

    [Parameter]
    public EventCallback Onclick { get; set; }

    /// <summary>
    /// The background color for the status badge based on the status enum
    /// </summary>
    private string color => Helpers.GetJobColor(statusEnum);

    /// <summary>
    /// Initializes the component and sets the appropriate color for the status badge
    /// </summary>
    protected override void OnInitialized()
    {
        Console.WriteLine(statusEnum.ToString());
    }
}

<style>
    .status-badge {
        color: var(--color-white);
        padding: 5px 10px;
        border-radius: 25px;
        font-weight: 600;
        font-size: 14px;
        text-align: center;
        max-width: 120px;
        cursor: @(Onclick.HasDelegate ? "pointer" : "default");
    }

</style>