@using Portal.Client.Components.UIComponents
@using Portal.Shared


@if (OnClick.HasDelegate)
{
    <div class="status-badge status-badge--clickable" style=@($"background-color: {Color(ContactType)}") @onclick="@(() => OnClick.InvokeAsync())">
        <span class="status-badge__text">@ContactType.GetDisplayName()</span>
    </div>
}
else
{
    <div class="status-badge" style=@($"background-color: {Color(ContactType)}")>
        <span class="status-badge__text">@ContactType.GetDisplayName()</span>
    </div>
}


@code {
    /// <summary>One or more job types (e.g. grid rows).</summary>
    [Parameter]
    public ContactTypeEnum ContactType { get; set; }

    [Parameter]
    public EventCallback OnClick { get; set; }


    private static string Color(ContactTypeEnum type) => Helpers.GetContactColour(type);

    private Task HandleClickAsync()
    {
        if (OnClick.HasDelegate)
            return OnClick.InvokeAsync();
        return Task.CompletedTask;
    }

}

<style>
    /* Fixed footprint so the badge looks the same in grids, headers, and detail pages */
    .status-badge {
        box-sizing: border-box;
        width: 140px;
        height: 28px;
        border-radius: 14px;
        color: var(--color-white);
        font-weight: 600;
        font-size: 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: default;
        overflow: hidden;
    }

    .status-badge--clickable {
        cursor: pointer;
    }

    .status-badge__text {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        max-width: 100%;
        padding: 0 8px;
        text-align: center;
    }

    .status-badge-split {
        box-sizing: border-box;
        width: 140px;
        height: 28px;
        display: inline-flex;
        flex-direction: row;
        align-items: stretch;
        border-radius: 14px;
        overflow: hidden;
        box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.08);
    }

    .status-badge-split--clickable {
        cursor: pointer;
    }

    .status-badge-half {
        box-sizing: border-box;
        color: var(--color-white);
        flex: 1 1 0;
        min-width: 0;
        min-height: 0;
        height: 100%;
        font-weight: 600;
        font-size: 11px;
        line-height: 1.2;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0 4px;
    }

    .status-badge-half__text {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        max-width: 100%;
        text-align: center;
    }

    .status-badge-half:not(:last-child) {
        box-shadow: inset -1px 0 0 rgba(255, 255, 255, 0.35);
    }
</style>
