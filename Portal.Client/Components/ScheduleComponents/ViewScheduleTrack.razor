@using Portal.Shared
@using Portal.Shared.DTO.Schedule
@using Portal.Shared.DTO.User

<div class="track-container border-rad">
    <Card ShowHeaderWithAddButton="!IsEditing" HeaderTitle="Assigned Users" CssClass="" OnAddButtonClick="@(() => IsEditing = true)" ButtonIcon="bi bi-pen" Shadow="false">
        <ChildContent>
            <div style="min-height: 60px">
                @if (IsEditing)
                {
                    <div class="border-rad padding grey-background">
                        <label>Assigned Users</label>
                        <MudSelect T="UserDto" MultiSelection="true" Variant="Variant.Outlined"
                                   ToStringFunc="@((x) => x.displayName)"
                                   SelectedValues="_selectedUsers"
                                   SelectedValuesChanged="OnSelectedUsersChanged">
                            @foreach (UserDto user in Users)
                            {
                                <MudSelectItem T="UserDto" Value="@user">@user.displayName</MudSelectItem>
                            }
                        </MudSelect>
                    </div>

                    <div class="d-flex justify-content-center gap-1 mt-1">
                        <ButtonIcon Icon="bi bi-save-fill" CssClass="text-green" Text="Save" ButtonType="submit" OnClick="@(() => SaveAssignedUsers())" />
                        <ButtonIcon Icon="bi bi-x-circle" Text="Close" CssClass="text-red" OnClick="@(() => IsEditing = false)" />
                    </div>
                }
                else
                {
                    if (Track.AssignedUsers.Count() is 0)
                    {
                        <small class="text-center">No Assigned Users</small>
                    }

                    @foreach (UserDto user in Track.AssignedUsers)
                    {
                        <div>@user.displayName</div>
                    }
                }
            </div>
            <div class="d-flex justify-content-end gap-1 mt-1">
                <ButtonIcon Icon="bi bi-plus" Title="Add" CssClass="text-green" OnClick="@(() => AddNewSchedule())" />
                <ButtonIcon Icon="bi bi-trash" Title="Delete" CssClass="text-red" OnClick="@(() => Delete(Track.TrackId))" />
            </div>
            <MudCalendar T="CustomCalendarItem"
                         ShowDatePicker="false"
                         View="@CalendarView.Day"
                         ShowPrevNextButtons="false"
                         CurrentDay="Track.Day.ToDateTime(new TimeOnly(7, 0))"
                         DayStartTime="new TimeOnly(7, 0, 0)"
                         ShowCurrentTime="true"
                         ShowMonth=false
                         ShowWeek=false
                         Items="Track.Events"
                         EnableDragItems="false"
                         Style="min-height: 660px !important"
                         DayCellHeight="26"
                         Class="">
                <CellTemplate>
                    <div class="schedule-items shadow-deep" style="border-left: 4px solid @(context.Colour ?? "#ccc"); background: var(--color-background)">
                        <b class="contact-link cursor-pointer" @onclick="@(() => OpenDialogAsync(context))">View</b>
                        <br/>
                        @if (context.JobAddress is not null && context.JobNumber is not null && context.JobId is not null)
                        {
                            <small style="">
                                <a class="contact-link" href=@($"/jobs/{context.JobId}")>
                                    Job: @context.JobNumber
                                </a>
                                - @context.JobAddress
                            </small>
                            <hr />
                        }
                        <small style="overflow: scroll">
                            <strong>Notes:</strong> @context.Text
                        </small>
                    </div>
                </CellTemplate>
            </MudCalendar>
        </ChildContent>
    </Card>
</div>

<style>
    .track-container {
        background-color: var(--color-light-grey);
        padding: 10px;
    }
</style>