@using Portal.Client.Webmodels
@using Portal.Shared.Helpers

<div class="day-view-calendar">
    <div class="day-view-column">
        <div class="day-view-grid" style="height: @(_totalHeightPx)px;">
            @for (int i = 0; i < _hourRows; i++)
            {
                <div class="day-view-hour-line" style="height: @(_hourHeightPx)px;"></div>
            }
        </div>
        <div class="day-view-events" style="height: @(_totalHeightPx)px;">
            @foreach (CustomCalendarItem evt in _visibleEvents)
            {
                var (topPx, heightPx) = GetEventPosition(evt);
                <div class="day-view-event schedule-items shadow-deep"
                     style="top: @(topPx)px; height: @(heightPx)px; border-left: 4px solid @(evt.Colour ?? "#ccc"); background: var(--color-background);"
                     @onclick="@(() => OnEventClick.InvokeAsync(evt))">
                    <b class="
cursor-pointer">View</b>
                    <br />
                    @if (evt.JobAddress is not null && evt.JobNumber is not null && evt.JobId is not null)
                    {
                        <small>
                            <a class="prs-link" href="@($"/jobs/{evt.JobId}")">Job: @(evt.JobNumber?.ToString() ?? "")</a>
                            - @evt.JobAddress
                        </small>
                        <hr />
                    }
                    <small class="day-view-event-notes"><strong>Notes:</strong> @evt.Text</small>
                </div>
            }
        </div>
    </div>
</div>



@code {
    private const int StartHour = 6;
    private const int EndHour = 18;
    private const int HourHeightPx = 60;
    private readonly int _hourHeightPx = HourHeightPx;
    private readonly int _totalHeightPx = (EndHour - StartHour) * HourHeightPx;
    private readonly int _hourRows = EndHour - StartHour;

    [Parameter] 
    public DateOnly Day { get; set; }
    [Parameter] 
    public List<CustomCalendarItem> Events { get; set; } = [];
    [Parameter] 
    public EventCallback<CustomCalendarItem> OnEventClick { get; set; }

    private List<CustomCalendarItem> _visibleEvents = [];
    private DateTime _dayStartUtc;
    private DateTime _dayEndUtc;

    protected override void OnParametersSet()
    {
        _dayStartUtc = Day.ToDateTime(new TimeOnly(StartHour, 0));
        _dayEndUtc = Day.ToDateTime(new TimeOnly(EndHour, 0));

        _visibleEvents = Events
            .Where(e =>
            {
                DateTime end = e.End ?? e.Start;
                return e.Start < _dayEndUtc && end > _dayStartUtc;
            })
            .ToList();
    }

    private (double topPx, double heightPx) GetEventPosition(CustomCalendarItem evt)
    {
        DateTime start = evt.Start < _dayStartUtc ? _dayStartUtc : evt.Start;
        DateTime end = evt.End ?? evt.Start;
        if (end > _dayEndUtc) end = _dayEndUtc;
        if (end <= start) end = start.AddMinutes(30);

        double startMinutes = (start - _dayStartUtc).TotalMinutes;
        double durationMinutes = (end - start).TotalMinutes;
        double totalMinutes = (EndHour - StartHour) * 60.0;

        double topPx = (startMinutes / totalMinutes) * _totalHeightPx;
        double heightPx = (durationMinutes / totalMinutes) * _totalHeightPx;
        if (heightPx < 24) heightPx = 24;

        return (topPx, heightPx);
    }

    
}
