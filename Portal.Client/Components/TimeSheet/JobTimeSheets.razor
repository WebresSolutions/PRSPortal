@using Portal.Shared.DTO.TimeSheet
@inject IDialogService DialogService
@inject IApiService ApiService
@inject ISnackbar Snackbar

<Card ShowHeaderWithAddButton="true" HeaderTitle=@($"Time: {TotalHours}hrs") OnAddButtonClick="OpenAddDialog">
    <ChildContent>
        @if (!TimeSheetsList.Any())
        {
            <div class="empty-state">No time entries yet</div>
        }
        else
        {
            <div class="timesheets-container">
                @foreach (TimeSheetDto entry in TimeSheetsList.OrderByDescending(e => e.Start))
                {
                    <div class="timesheet-entry">
                        <div class="timesheet-fields">
                            <div class="timesheet-field timesheet-field-main">
                                <span class="timesheet-time">
                                    @entry.Start.ToLocalTime().ToString("HH:mm")
                                    @if (entry.End is not null)
                                    {
                                        <span class="timesheet-time-sep">–</span>
                                        @entry.End.Value.ToLocalTime().ToString("HH:mm")
                                    }
                                    else
                                    {
                                        <span class="timesheet-live">· In progress</span>
                                    }
                                </span>
                                @if (entry.End is not null)
                                {
                                    <span class="timesheet-duration">@FormatDuration(entry.Start, entry.End.Value)</span>
                                }
                            </div>
                            <div class="timesheet-field">
                                <span class="timesheet-label">Date</span>
                                <span class="timesheet-value">@entry.Start.ToString("ddd d MMM yyyy")</span>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(entry.Description))
                            {
                                <div class="timesheet-field">
                                    <span class="timesheet-label">Description</span>
                                    <span class="timesheet-value timesheet-desc">@entry.Description</span>
                                </div>
                            }
                            @if (!string.IsNullOrWhiteSpace(entry.UserDisplayName))
                            {
                                <div class="timesheet-field">
                                    <span class="timesheet-label">User</span>
                                    <span class="timesheet-value">@entry.UserDisplayName</span>
                                </div>
                            }
                        </div>
                        <div class="timesheet-actions">
                            <ButtonIcon Icon="bi bi-pencil" Title="Edit" OnClick="@(() => OpenEditDialog(entry))" />
                            <ButtonIcon Icon="bi bi-trash" Title="Delete" CssClass="text-red" OnClick="@(() => DeleteEntry(entry))" />
                        </div>
                    </div>
                }
            </div>
        }
    </ChildContent>
</Card>


